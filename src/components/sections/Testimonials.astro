---
import { TESTIMONIALS_CONTENT } from '@config';
---

<section class="testimonials" aria-labelledby="testimonials-heading">
  <div class="testimonials__inner">
    <div class="testimonials__header">
      <span class="testimonials__eyebrow">{TESTIMONIALS_CONTENT.eyebrow}</span>
      <h2 id="testimonials-heading" class="testimonials__heading">{TESTIMONIALS_CONTENT.heading}</h2>
      <p class="testimonials__subtext">
        {TESTIMONIALS_CONTENT.subtext}
      </p>
    </div>

    <div class="testimonials__grid" role="list">
      {TESTIMONIALS_CONTENT.items.map((t, index) => (
        <blockquote class="testimonials__card" role="listitem" data-animate="scale-in" style={`--delay: ${index * 100}ms`}>
          <p class="testimonials__quote">{t.quote}</p>
          <footer class="testimonials__author">
            <div class="testimonials__avatar" aria-hidden="true">
              {t.name.charAt(0)}
            </div>
            <div>
              <cite class="testimonials__name">{t.name}</cite>
              <span class="testimonials__role">{t.role}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: var(--space-20) var(--space-6);
    background: var(--color-neutral-0);
  }

  .testimonials__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .testimonials__eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }

  .testimonials__subtext {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .testimonials__card {
    padding: var(--space-8);
    margin: 0;
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .testimonials__quote {
    font-size: var(--text-base);
    color: var(--color-neutral-900);
    line-height: var(--leading-normal);
    margin: 0;
    flex: 1;
  }

  .testimonials__quote::before {
    content: '\201C';
    font-size: var(--text-2xl);
    color: var(--color-primary-500);
    font-weight: var(--font-weight-bold);
    line-height: 0;
    margin-right: 2px;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .testimonials__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--color-primary-50);
    color: var(--color-primary-600);
    font-weight: var(--font-weight-bold);
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .testimonials__name {
    display: block;
    font-style: normal;
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    font-size: var(--text-base);
  }

  .testimonials__role {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
  }

  @media (min-width: 768px) {
    .testimonials__heading { font-size: var(--text-4xl); }
  }

  @media (max-width: 1024px) {
    .testimonials__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .testimonials { padding: var(--space-12) var(--space-6); }
    .testimonials__grid { grid-template-columns: 1fr; }
  }
</style>
