---
/**
 * NavMobile — mobile hamburger button + dropdown menu.
 * Extracted from Navbar to keep files under the 300-line cap.
 * Receives nav links and current path from parent Navbar.
 */

import Container from '@components/ui/Container.astro';
import './nav-mobile.css';

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links: NavLink[];
  currentPath: string;
}

const { links, currentPath } = Astro.props;
---

<!-- Mobile hamburger -->
<button
  id="hamburger"
  class="navbar__hamburger"
  type="button"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-menu"
>
  <span class="hamburger__bar" aria-hidden="true"></span>
  <span class="hamburger__bar" aria-hidden="true"></span>
  <span class="hamburger__bar" aria-hidden="true"></span>
</button>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="navbar__mobile-menu"
  role="navigation"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <Container>
    <ul class="navbar__mobile-links" role="list">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'navbar__mobile-link',
              { 'navbar__mobile-link--active': currentPath === link.href || currentPath.startsWith(link.href + '/') },
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="navbar__mobile-cta">
      <a href="/plan-my-trip" class="navbar__mobile-cta-link">
        Plan My Trip
      </a>
    </div>
  </Container>
</div>

