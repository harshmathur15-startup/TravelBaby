---
import { SITE_CONFIG } from '@config';

const currentYear = new Date().getFullYear();
---

<footer class="footer" aria-label="Site footer">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label={`${SITE_CONFIG.name} — go to homepage`}>
          <span class="footer__logo-text">{SITE_CONFIG.name}</span>
        </a>
        <div class="footer__newsletter">
          <h3 class="footer__newsletter-heading">{SITE_CONFIG.newsletter.heading}</h3>
          <p class="footer__newsletter-subtext">{SITE_CONFIG.newsletter.subtext}</p>
          <form class="footer__newsletter-form" aria-label="Newsletter signup">
            <label for="footer-email" class="sr-only">Email address</label>
            <input type="email" id="footer-email" class="footer__newsletter-input" placeholder={SITE_CONFIG.newsletter.placeholder} required aria-label="Email address for newsletter" />
            <button type="submit" class="footer__newsletter-btn" aria-label="Subscribe to newsletter">Subscribe</button>
          </form>
        </div>
      </div>

      <div class="footer__columns">
        {SITE_CONFIG.footerColumns.map((col) => (
          <div class="footer__column">
            <h3 class="footer__column-title">{col.title}</h3>
            <ul class="footer__column-links" role="list">
              {col.links.map((link) => (
                <li><a href={link.href} class="footer__link">{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {currentYear} {SITE_CONFIG.copyright}. All rights reserved.</p>
      <div class="footer__social" role="list" aria-label="Social media links">
        {SITE_CONFIG.socialLinks.map((social) => (
          <a href={social.href} class="footer__social-link" aria-label={social.label} role="listitem" set:html={social.icon} />
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  .footer { padding: 4rem 1.5rem 2rem; background: var(--color-text, #111827); color: var(--color-bg, #fff); }
  .footer__inner { max-width: 1200px; margin: 0 auto; }

  .footer__top {
    display: grid; grid-template-columns: 1fr 2fr; gap: 4rem;
    padding-bottom: 3rem; border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__logo {
    text-decoration: none; color: #fff; font-size: 1.25rem;
    font-weight: 700; display: inline-block; margin-bottom: 1.5rem;
  }

  .footer__logo-text {
    background: linear-gradient(135deg, #60a5fa, #93c5fd);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  .footer__newsletter { max-width: 320px; }
  .footer__newsletter-heading { font-size: 0.9375rem; font-weight: 600; color: #fff; margin: 0 0 0.5rem; }
  .footer__newsletter-subtext { font-size: 0.8125rem; color: rgba(255, 255, 255, 0.6); margin: 0 0 1rem; line-height: 1.5; }
  .footer__newsletter-form { display: flex; gap: 0.5rem; }

  .footer__newsletter-input {
    flex: 1; padding: 0.5rem 0.75rem; font-size: 0.875rem;
    background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.375rem; color: #fff; outline: none; transition: border-color 0.2s;
  }

  .footer__newsletter-input::placeholder { color: rgba(255, 255, 255, 0.4); }
  .footer__newsletter-input:focus { border-color: rgba(255, 255, 255, 0.5); }

  .footer__newsletter-btn {
    padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 600;
    background: var(--color-primary, #2563eb); color: #fff; border: none;
    border-radius: 0.375rem; cursor: pointer; white-space: nowrap; transition: background 0.2s;
  }

  .footer__newsletter-btn:hover { background: var(--color-primary-dark, #1d4ed8); }

  .footer__columns { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }

  .footer__column-title {
    font-size: 0.8125rem; font-weight: 600; color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 1rem;
  }

  .footer__column-links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; }
  .footer__link { text-decoration: none; color: rgba(255, 255, 255, 0.7); font-size: 0.875rem; transition: color 0.2s; }
  .footer__link:hover { color: #fff; }

  .footer__bottom { display: flex; align-items: center; justify-content: space-between; padding-top: 2rem; }
  .footer__copyright { font-size: 0.8125rem; color: rgba(255, 255, 255, 0.4); margin: 0; }
  .footer__social { display: flex; gap: 1rem; }
  .footer__social-link { display: flex; align-items: center; justify-content: center; color: rgba(255, 255, 255, 0.5); transition: color 0.2s; }
  .footer__social-link:hover { color: #fff; }

  @media (max-width: 1024px) {
    .footer__top { grid-template-columns: 1fr; gap: 3rem; }
    .footer__columns { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .footer { padding: 3rem 1.5rem 1.5rem; }
    .footer__columns { grid-template-columns: 1fr 1fr; }
    .footer__bottom { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>
