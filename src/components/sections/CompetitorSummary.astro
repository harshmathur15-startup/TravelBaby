---
/**
 * CompetitorSummary — detailed side-by-side competitor comparison with
 * pros, cons, pricing, and verdict. Complements CompetitorCards (quick
 * glance grid) with a richer breakdown per competitor.
 */

import Container from '@components/ui/Container.astro'
import SectionHeading from '@components/ui/SectionHeading.astro'
import Badge from '@components/ui/Badge.astro'

interface CompetitorDetail {
  name: string
  strengths: string[]
  weaknesses: string[]
  pricing: string
  verdict: string
  recommended?: boolean
}

interface Props {
  eyebrow?: string
  heading?: string
  subtext?: string
  items?: CompetitorDetail[]
}

const DEFAULT_COMPETITORS: CompetitorDetail[] = [
  {
    name: 'Our Product',
    strengths: ['Modern architecture', 'Transparent pricing', 'Fast onboarding'],
    weaknesses: ['Newer to market', 'Smaller partner ecosystem'],
    pricing: 'From $X/mo',
    verdict: 'Best fit for teams that value speed and simplicity.',
    recommended: true,
  },
  {
    name: 'Competitor A',
    strengths: ['Large feature set', 'Strong brand recognition'],
    weaknesses: ['Complex setup', 'Opaque pricing tiers'],
    pricing: 'Custom quotes',
    verdict: 'Good for enterprises with dedicated admin teams.',
  },
  {
    name: 'Competitor B',
    strengths: ['Clean interface', 'Solid core workflows'],
    weaknesses: ['Limited integrations', 'Add-on costs add up'],
    pricing: 'From $Y/user/mo',
    verdict: 'Works for small teams with simple needs.',
  },
]

const {
  eyebrow = 'Deep Dive',
  heading = 'Detailed Comparison',
  subtext = 'A closer look at strengths, weaknesses, and trade-offs across the top options.',
  items,
} = Astro.props

const competitors = items?.length ? items : DEFAULT_COMPETITORS
---

<section class="comp-summary" aria-labelledby="comp-summary-heading">
  <Container>
    <SectionHeading
      id="comp-summary-heading"
      title={heading}
      subtitle={subtext}
      as="h2"
    />
    {eyebrow && <p class="comp-summary__eyebrow">{eyebrow}</p>}

    <div class="comp-summary__grid" role="list">
      {competitors.map((c) => (
        <div
          class:list={['comp-summary__card', { 'comp-summary__card--recommended': c.recommended }]}
          role="listitem"
        >
          <div class="comp-summary__header">
            <h3 class="comp-summary__name">{c.name}</h3>
            {c.recommended && <Badge variant="primary">Recommended</Badge>}
          </div>

          <p class="comp-summary__pricing">{c.pricing}</p>

          <div class="comp-summary__section">
            <span class="comp-summary__label comp-summary__label--pro">Strengths</span>
            <ul class="comp-summary__list" role="list">
              {c.strengths.map((s) => (
                <li class="comp-summary__item comp-summary__item--pro">{s}</li>
              ))}
            </ul>
          </div>

          <div class="comp-summary__section">
            <span class="comp-summary__label comp-summary__label--con">Weaknesses</span>
            <ul class="comp-summary__list" role="list">
              {c.weaknesses.map((w) => (
                <li class="comp-summary__item comp-summary__item--con">{w}</li>
              ))}
            </ul>
          </div>

          <p class="comp-summary__verdict">{c.verdict}</p>
        </div>
      ))}
    </div>
  </Container>
</section>

<style>
  .comp-summary {
    padding: var(--space-16) 0;
    background-color: var(--color-neutral-0);
  }

  .comp-summary__eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary-500);
    text-align: center;
    margin: calc(-1 * var(--space-8)) 0 var(--space-4);
  }

  .comp-summary__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .comp-summary__card {
    padding: var(--space-6);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    background-color: var(--color-neutral-0);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .comp-summary__card--recommended {
    border-color: var(--color-primary-500);
    border-width: 2px;
    background-color: var(--color-primary-50);
    box-shadow: var(--shadow-lg);
  }

  .comp-summary__header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .comp-summary__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    margin: 0;
  }

  .comp-summary__pricing {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-600);
    margin: 0;
  }

  .comp-summary__section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .comp-summary__label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .comp-summary__label--pro { color: var(--color-success-dark); }
  .comp-summary__label--con { color: var(--color-error-dark); }

  .comp-summary__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .comp-summary__item {
    font-size: var(--text-sm);
    color: var(--color-neutral-700);
    line-height: var(--leading-normal);
    padding-left: var(--space-5);
    position: relative;
  }

  .comp-summary__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    width: 12px;
    height: 12px;
    mask-size: contain;
    mask-repeat: no-repeat;
  }

  .comp-summary__item--pro::before {
    background: var(--color-success-dark);
    mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M13.3 4.3a1 1 0 0 1 0 1.4l-6 6a1 1 0 0 1-1.4 0l-3-3a1 1 0 1 1 1.4-1.4L6.6 9.6l5.3-5.3a1 1 0 0 1 1.4 0z' fill='currentColor'/%3E%3C/svg%3E");
  }

  .comp-summary__item--con::before {
    background: var(--color-error-dark);
    mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4.7 4.7a1 1 0 0 1 1.4 0L8 6.6l1.9-1.9a1 1 0 1 1 1.4 1.4L9.4 8l1.9 1.9a1 1 0 0 1-1.4 1.4L8 9.4l-1.9 1.9a1 1 0 0 1-1.4-1.4L6.6 8 4.7 6.1a1 1 0 0 1 0-1.4z' fill='currentColor'/%3E%3C/svg%3E");
  }

  .comp-summary__verdict {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-neutral-500);
    margin: 0;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-neutral-100);
  }

  @media (min-width: 640px) {
    .comp-summary__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .comp-summary {
      padding: var(--space-20) 0;
    }

    .comp-summary__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
