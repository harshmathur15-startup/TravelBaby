---
import { HERO_CONTENT } from '@config';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">
    <div class="hero__badge" aria-label="Announcement badge">
      <span class="hero__badge-dot" aria-hidden="true"></span>
      {HERO_CONTENT.badge}
    </div>

    <h1 id="hero-heading" class="hero__heading" set:html={HERO_CONTENT.heading} />

    <p class="hero__subtext">
      {HERO_CONTENT.subtext}
    </p>

    <div class="hero__actions">
      <a href={HERO_CONTENT.primaryCta.href} class="hero__cta hero__cta--primary" aria-label={HERO_CONTENT.primaryCta.label}>
        {HERO_CONTENT.primaryCta.label}
      </a>
      <a href={HERO_CONTENT.secondaryCta.href} class="hero__cta hero__cta--ghost" aria-label={HERO_CONTENT.secondaryCta.label}>
        {HERO_CONTENT.secondaryCta.label}
      </a>
    </div>

    <p class="hero__trust" aria-label="Social proof">
      {HERO_CONTENT.trustLine}
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-24) var(--space-6) var(--space-16);
    text-align: center;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--color-primary-50) 0%,
      var(--color-accent-50) 25%,
      var(--color-primary-100) 50%,
      var(--color-accent-50) 75%,
      var(--color-primary-50) 100%
    );
    background-size: 400% 400%;
    animation: aurora-shift 12s ease-in-out infinite;
  }

  @keyframes aurora-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero { animation: none; background-size: 100% 100%; }
  }

  .hero__inner {
    max-width: var(--container-lg);
    margin: 0 auto;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-4);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary-600);
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-200);
    border-radius: var(--radius-full);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary-500);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-neutral-950);
    margin: 0 0 var(--space-5);
  }

  .hero__subtext {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-600);
    margin: 0 auto var(--space-8);
    max-width: 600px;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-10);
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-8);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: background var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast);
  }

  .hero__cta--primary {
    background: var(--color-primary-500);
    color: var(--color-neutral-0);
    box-shadow: var(--shadow-sm);
  }

  .hero__cta--primary:hover {
    background: var(--color-primary-600);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .hero__cta--ghost {
    background: transparent;
    color: var(--color-neutral-900);
    border: 1px solid var(--color-neutral-200);
  }

  .hero__cta--ghost:hover {
    background: var(--color-neutral-50);
    border-color: var(--color-neutral-400);
  }

  .hero__trust {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-neutral-400);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin: 0;
  }

  @media (min-width: 768px) {
    .hero__heading { font-size: var(--text-5xl); }
  }

  @media (max-width: 640px) {
    .hero { padding: var(--space-16) var(--space-6) var(--space-12); }
    .hero__actions { flex-direction: column; align-items: center; }
    .hero__cta { width: 100%; max-width: 300px; justify-content: center; }
  }
</style>
