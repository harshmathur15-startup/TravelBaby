---
/**
 * PricingCard — single pricing tier card with price, features, and CTA.
 * Extracted from PricingCards.astro for reuse and to respect the 300-line cap.
 * Supports monthly/annual toggle via data attributes on the amount element.
 */

interface Props {
  name: string;
  description: string;
  monthlyPrice: number | null;
  annualPrice: number | null;
  features: string[];
  cta: string;
  ctaHref: string;
  popular?: boolean;
  currency?: string;
}

const {
  name,
  description,
  monthlyPrice,
  annualPrice,
  features,
  cta,
  ctaHref,
  popular = false,
  currency = '$',
} = Astro.props;
---

<div class:list={['pricing-card', { 'pricing-card--popular': popular }]} role="listitem">
  {popular && <span class="pricing-card__badge">Most Popular</span>}
  <h3 class="pricing-card__name">{name}</h3>
  <p class="pricing-card__desc">{description}</p>
  <div class="pricing-card__price">
    {monthlyPrice !== null ? (
      <>
        <span class="pricing-card__currency">{currency}</span>
        <span class="pricing-card__amount" data-monthly={monthlyPrice} data-annual={annualPrice}>{monthlyPrice}</span>
        <span class="pricing-card__period">/mo</span>
      </>
    ) : (
      <span class="pricing-card__custom">Contact us</span>
    )}
  </div>
  <a
    href={ctaHref}
    class:list={['pricing-card__cta', popular ? 'pricing-card__cta--primary' : 'pricing-card__cta--outline']}
    aria-label={`${cta} — ${name} plan`}
  >
    {cta}
  </a>
  <ul class="pricing-card__features" role="list">
    {features.map((feature) => (
      <li class="pricing-card__feature">
        <svg class="pricing-card__check" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        {feature}
      </li>
    ))}
  </ul>
</div>

<style>
  .pricing-card {
    position: relative;
    padding: var(--space-8);
    background: var(--color-neutral-0);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
  }

  .pricing-card--popular {
    border-color: var(--color-primary-500);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .pricing-card__badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    padding: var(--space-1) var(--space-4);
    background: var(--color-primary-500);
    color: var(--color-neutral-0);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .pricing-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    margin: 0 0 var(--space-2);
  }

  .pricing-card__desc {
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    margin: 0 0 var(--space-6);
    line-height: var(--leading-normal);
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin-bottom: var(--space-6);
  }

  .pricing-card__currency {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
  }

  .pricing-card__amount {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }

  .pricing-card__period {
    font-size: var(--text-base);
    color: var(--color-neutral-600);
    font-weight: var(--font-weight-medium);
  }

  .pricing-card__custom {
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
  }

  .pricing-card__cta {
    display: block;
    width: 100%;
    padding: var(--space-3);
    text-align: center;
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: background var(--duration-fast), transform var(--duration-fast);
    margin-bottom: var(--space-6);
  }

  .pricing-card__cta--primary {
    background: var(--color-primary-500);
    color: var(--color-neutral-0);
  }

  .pricing-card__cta--primary:hover {
    background: var(--color-primary-600);
    transform: translateY(-1px);
  }

  .pricing-card__cta--outline {
    background: transparent;
    color: var(--color-primary-600);
    border: 1px solid var(--color-primary-500);
  }

  .pricing-card__cta--outline:hover {
    background: var(--color-primary-50);
  }

  .pricing-card__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex-grow: 1;
  }

  .pricing-card__feature {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
  }

  .pricing-card__check {
    color: var(--color-success);
    flex-shrink: 0;
  }
</style>
