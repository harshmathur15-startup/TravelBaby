---
/**
 * ProductFAQ — CSS-only accordion for product-specific FAQs.
 * Uses details/summary for zero-JS interactivity. Includes FAQPage JSON-LD for SEO.
 * Matches the template FAQ.astro pattern but accepts items via props instead of config.
 */

import Container from '@components/ui/Container.astro'

interface FaqItem {
  question: string
  answer: string
}

interface Props {
  heading?: string
  subtext?: string
  items: FaqItem[]
  productName?: string
}

const {
  heading,
  subtext,
  items,
  productName,
} = Astro.props

const resolvedHeading = heading ?? (productName ? `${productName} FAQ` : 'Frequently Asked Questions')

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
})
---

<section class="product-faq" aria-labelledby="product-faq-heading">
  <Container size="lg">
    <div class="product-faq__header">
      <h2 id="product-faq-heading" class="product-faq__heading">{resolvedHeading}</h2>
      {subtext && <p class="product-faq__subtext">{subtext}</p>}
    </div>
    <div class="product-faq__list">
      {items.map((faq) => (
        <details class="product-faq__item" name="product-faq">
          <summary class="product-faq__question">
            <span>{faq.question}</span>
            <svg
              class="product-faq__chevron"
              aria-hidden="true"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div class="product-faq__answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </Container>
</section>

{items.length > 0 && <script type="application/ld+json" set:html={faqJsonLd} />}

<style>
  .product-faq {
    padding: var(--space-16) 0;
    background-color: var(--color-neutral-50);
  }

  .product-faq__header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .product-faq__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }

  .product-faq__subtext {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .product-faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .product-faq__item {
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--duration-fast);
  }

  .product-faq__item[open] {
    border-color: var(--color-primary-200);
  }

  .product-faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-neutral-950);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .product-faq__question::-webkit-details-marker {
    display: none;
  }

  .product-faq__question::marker {
    display: none;
    content: '';
  }

  .product-faq__question:focus-visible {
    outline: 2px solid var(--color-primary-500);
    outline-offset: -2px;
    border-radius: var(--radius-lg);
  }

  .product-faq__chevron {
    flex-shrink: 0;
    color: var(--color-neutral-400);
    transition: transform var(--duration-fast);
  }

  .product-faq__item[open] .product-faq__chevron {
    transform: rotate(180deg);
  }

  .product-faq__answer {
    padding: 0 var(--space-5) var(--space-5);
  }

  .product-faq__answer p {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-600);
    margin: 0;
  }

  @media (min-width: 768px) {
    .product-faq {
      padding: var(--space-20) 0;
    }
    .product-faq__heading {
      font-size: var(--text-4xl);
    }
    .product-faq__question {
      font-size: var(--text-lg);
      padding: var(--space-6);
    }
    .product-faq__answer {
      padding: 0 var(--space-6) var(--space-6);
    }
  }

  @media (max-width: 640px) {
    .product-faq {
      padding: var(--space-12) var(--space-6);
    }
  }
</style>
