---
/**
 * PricingAddons — grid of add-on modules with feature lists.
 * Designed to sit below PricingCards. Complements AddOns.astro
 * (simple name/description/price cards) with a richer layout
 * that includes per-module feature bullet lists.
 */

import Container from '@components/ui/Container.astro'

interface PricingAddon {
  name: string
  price: string
  features: string[]
}

interface Props {
  heading?: string
  subtext?: string
  items?: PricingAddon[]
}

const DEFAULT_ADDONS: PricingAddon[] = [
  {
    name: 'Advanced Reporting',
    price: '$29/mo',
    features: ['Custom Dashboards', 'Scheduled Exports', 'Data Visualization', 'Team Benchmarks'],
  },
  {
    name: 'Workflow Automation',
    price: '$19/mo',
    features: ['Trigger-based Actions', 'Approval Chains', 'Conditional Logic', 'Audit Trail'],
  },
  {
    name: 'Priority Support',
    price: '$49/mo',
    features: ['4-hour Response SLA', 'Dedicated Channel', 'Onboarding Assistance', 'Quarterly Review'],
  },
  {
    name: 'API Access',
    price: '$39/mo',
    features: ['REST API', '10,000 Requests/Day', 'Webhook Events', 'Developer Docs'],
  },
  {
    name: 'White Label',
    price: 'Contact Sales',
    features: ['Custom Domain', 'Branded Emails', 'Themed Portal', 'Removable Branding'],
  },
  {
    name: 'Data Migration',
    price: 'Contact Sales',
    features: ['Guided Import', 'Schema Mapping', 'Validation Reports', 'Rollback Support'],
  },
]

const {
  heading = 'Add-on Modules',
  subtext = 'Extend your plan with specialized modules.',
  items,
} = Astro.props

const addons = items?.length ? items : DEFAULT_ADDONS
---

<div class="pricing-addons" role="region" aria-label={heading}>
  <Container>
    <h3 class="pricing-addons__heading">{heading}</h3>
    <p class="pricing-addons__subtext">{subtext}</p>

    <div class="pricing-addons__grid" role="list">
      {addons.map((addon) => (
        <div class="pricing-addons__card" role="listitem">
          <div class="pricing-addons__header">
            <h4 class="pricing-addons__name">{addon.name}</h4>
            <span class="pricing-addons__price">{addon.price}</span>
          </div>
          <ul class="pricing-addons__features" role="list">
            {addon.features.map((f) => (
              <li>{f}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </Container>
</div>

<style>
  .pricing-addons {
    margin-top: var(--space-16);
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-neutral-200);
  }

  .pricing-addons__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    text-align: center;
    margin: 0 0 var(--space-2);
  }

  .pricing-addons__subtext {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    text-align: center;
    margin: 0 0 var(--space-8);
  }

  .pricing-addons__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .pricing-addons__card {
    background: var(--color-neutral-0);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .pricing-addons__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-3);
    gap: var(--space-2);
  }

  .pricing-addons__name {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    margin: 0;
  }

  .pricing-addons__price {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary-600);
    white-space: nowrap;
  }

  .pricing-addons__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
  }

  .pricing-addons__features li {
    font-size: var(--text-xs);
    color: var(--color-neutral-600);
    position: relative;
    padding-left: var(--space-4);
    line-height: var(--leading-normal);
  }

  .pricing-addons__features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    width: 12px;
    height: 12px;
    background: var(--color-success);
    mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M13.3 4.3a1 1 0 0 1 0 1.4l-6 6a1 1 0 0 1-1.4 0l-3-3a1 1 0 1 1 1.4-1.4L6.6 9.6l5.3-5.3a1 1 0 0 1 1.4 0z' fill='currentColor'/%3E%3C/svg%3E");
    mask-size: contain;
    mask-repeat: no-repeat;
  }

  @media (min-width: 640px) {
    .pricing-addons__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pricing-addons__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
