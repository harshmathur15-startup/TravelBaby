---
/**
 * ProductModules — Timeline-style module list for product sub-features.
 * Vertical dot-and-line indicator with content blocks. Centered, single column.
 */

import Container from '@components/ui/Container.astro'

interface Module {
  name: string
  description: string
  icon?: string
}

interface Props {
  heading?: string
  subtext?: string
  modules: Module[]
  productName?: string
}

const {
  heading,
  subtext,
  modules,
  productName,
} = Astro.props

const resolvedHeading = heading ?? (productName ? `${productName} Modules` : 'Modules')
---

<section class="product-modules" aria-labelledby="product-modules-heading">
  <Container>
    <div class="product-modules__header">
      <h2 id="product-modules-heading" class="product-modules__heading">{resolvedHeading}</h2>
      {subtext && <p class="product-modules__subtext">{subtext}</p>}
    </div>
    <div class="product-modules__list" role="list">
      {modules.map((mod, i) => (
        <article class="module-card" role="listitem">
          <div class="module-card__indicator" aria-hidden="true">
            <div class="module-card__dot" />
            {i < modules.length - 1 && <div class="module-card__line" />}
          </div>
          <div class="module-card__content">
            {mod.icon && <div class="module-card__icon" aria-hidden="true">{mod.icon}</div>}
            <h3 class="module-card__title">{mod.name}</h3>
            <p class="module-card__description">{mod.description}</p>
          </div>
        </article>
      ))}
    </div>
  </Container>
</section>

<style>
  .product-modules {
    padding: var(--space-16) 0;
    background-color: var(--color-neutral-50);
  }

  .product-modules__header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .product-modules__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }

  .product-modules__subtext {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    max-width: var(--container-sm);
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .product-modules__list {
    display: flex;
    flex-direction: column;
    max-width: 36rem;
    margin: 0 auto;
  }

  .module-card {
    display: flex;
    gap: var(--space-4);
  }

  .module-card__indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 24px;
  }

  .module-card__dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary-500);
    flex-shrink: 0;
  }

  .module-card__line {
    width: 2px;
    flex: 1;
    background-color: var(--color-neutral-200);
  }

  .module-card__content {
    padding-bottom: var(--space-8);
  }

  .module-card:last-child .module-card__content {
    padding-bottom: 0;
  }

  .module-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--color-primary-500);
    margin-bottom: var(--space-2);
  }

  .module-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    margin: 0 0 var(--space-1);
    line-height: var(--leading-tight);
  }

  .module-card__description {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-600);
    margin: 0;
  }

  @media (min-width: 768px) {
    .product-modules {
      padding: var(--space-20) 0;
    }
    .product-modules__heading {
      font-size: var(--text-4xl);
    }
    .module-card__title {
      font-size: var(--text-xl);
    }
  }
</style>
