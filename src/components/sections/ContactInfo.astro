---
/**
 * ContactInfo — contact details card with optional social links and location callout.
 * Accepts all content via props — no hardcoded data.
 */

interface Social {
  platform: string;
  url: string;
  icon?: string;
}

interface Props {
  heading?: string;
  subtext?: string;
  email?: string;
  phone?: string;
  address?: string;
  hours?: string;
  socials?: Social[];
  locationCallout?: string;
}

const {
  heading = 'Contact Information',
  subtext,
  email,
  phone,
  address,
  hours,
  socials = [],
  locationCallout,
} = Astro.props;
---

<div class="contact-info" data-animate="fade-up">
  <div class="contact-info__card">
    <h2 class="contact-info__title">{heading}</h2>
    {subtext && <p class="contact-info__subtext">{subtext}</p>}

    <dl class="contact-info__list">
      {email && (
        <div class="contact-info__item">
          <dt class="contact-info__label">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </dt>
          <dd>
            <a href={`mailto:${email}`} class="contact-info__link">{email}</a>
          </dd>
        </div>
      )}

      {phone && (
        <div class="contact-info__item">
          <dt class="contact-info__label">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Phone
          </dt>
          <dd>
            <a href={`tel:${phone.replace(/[^+\d]/g, '')}`} class="contact-info__link">{phone}</a>
          </dd>
        </div>
      )}

      {address && (
        <div class="contact-info__item">
          <dt class="contact-info__label">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            Address
          </dt>
          <dd class="contact-info__address">{address}</dd>
        </div>
      )}

      {hours && (
        <div class="contact-info__item">
          <dt class="contact-info__label">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Office Hours
          </dt>
          <dd>{hours}</dd>
        </div>
      )}
    </dl>

    {socials.length > 0 && (
      <div class="contact-info__social">
        <h3 class="contact-info__social-title">Follow Us</h3>
        <div class="contact-info__social-links">
          {socials.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.platform}
              class="contact-info__social-icon"
            >
              {social.icon ? (
                <Fragment set:html={social.icon} />
              ) : (
                <span>{social.platform.charAt(0)}</span>
              )}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

  {locationCallout && (
    <div class="contact-info__location">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="contact-info__location-icon"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
      <p class="contact-info__location-text" set:html={locationCallout} />
    </div>
  )}
</div>

<style>
  .contact-info__card {
    background-color: var(--color-neutral-50);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }

  .contact-info__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    margin-bottom: var(--space-2);
  }

  .contact-info__subtext {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-600);
    margin-bottom: var(--space-8);
  }

  .contact-info__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-info__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-info__label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-800);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-info__label svg {
    color: var(--color-primary-500);
    flex-shrink: 0;
  }

  .contact-info__item dd {
    font-size: var(--text-base);
    color: var(--color-neutral-700);
    padding-left: calc(20px + var(--space-2));
  }

  .contact-info__link {
    color: var(--color-primary-500);
    transition: color var(--duration-normal) var(--ease-in-out);
  }

  .contact-info__link:hover {
    color: var(--color-primary-700);
  }

  .contact-info__address {
    font-style: normal;
    line-height: var(--leading-relaxed);
  }

  .contact-info__social {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-neutral-200);
  }

  .contact-info__social-title {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-800);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .contact-info__social-links {
    display: flex;
    gap: var(--space-3);
  }

  .contact-info__social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background-color: var(--color-neutral-100);
    color: var(--color-neutral-600);
    transition: background-color var(--duration-normal) var(--ease-in-out),
                color var(--duration-normal) var(--ease-in-out);
  }

  .contact-info__social-icon:hover {
    background-color: var(--color-primary-500);
    color: white;
  }

  .contact-info__location {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-primary-50);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-primary-100);
  }

  .contact-info__location-icon {
    color: var(--color-primary-500);
    flex-shrink: 0;
  }

  .contact-info__location-text {
    font-size: var(--text-base);
    color: var(--color-neutral-800);
    line-height: var(--leading-normal);
    margin: 0;
  }
</style>
