---
/**
 * HeroTrustBar — trust bar with label and logo placeholders.
 * Extracted from Hero.astro for component size compliance.
 */

interface Props {
  trustLine: string
  trustLogos: string[]
}

const { trustLine, trustLogos } = Astro.props
---

<div class="hero__trust" data-animate="fade-up" style="--delay: 400ms">
  <p class="hero__trust-label">{trustLine}</p>
  <div class="hero__logos">
    {
      trustLogos.map(name => (
        <div class="hero__logo-slot" role="img" aria-label={name}>
          <span class="hero__logo-text">{name}</span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .hero__trust {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-neutral-200);
    text-align: center;
  }

  .hero__trust-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-neutral-600);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-5);
  }

  .hero__logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-6);
  }

  .hero__logo-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
  }

  .hero__logo-text {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-600);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    user-select: none;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .hero__logo-text {
      font-size: var(--text-sm);
    }
  }
</style>
