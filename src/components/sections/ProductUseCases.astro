---
/**
 * ProductUseCases — Numbered scenario cards with problem/solution pairs.
 * Stacked list with header bars and body content. Centered, max-width constrained.
 */

import Container from '@components/ui/Container.astro'

interface UseCase {
  title: string
  problem?: string
  solution?: string
  description?: string
}

interface Props {
  heading?: string
  subtext?: string
  useCases: UseCase[]
  productName?: string
}

const {
  heading,
  subtext,
  useCases,
  productName,
} = Astro.props

const resolvedHeading = heading ?? (productName ? `${productName} Use Cases` : 'Real-World Scenarios')
---

<section class="product-use-cases" aria-labelledby="product-use-cases-heading">
  <Container>
    <div class="product-use-cases__header">
      <h2 id="product-use-cases-heading" class="product-use-cases__heading">{resolvedHeading}</h2>
      {subtext && <p class="product-use-cases__subtext">{subtext}</p>}
    </div>
    <div class="product-use-cases__list" role="list">
      {useCases.map((uc, i) => (
        <article class="use-case" role="listitem">
          <div class="use-case__header">
            <span class="use-case__number" aria-hidden="true">{i + 1}</span>
            <h3 class="use-case__title">{uc.title}</h3>
          </div>
          <div class="use-case__body">
            {uc.description && (
              <p class="use-case__text">{uc.description}</p>
            )}
            {uc.problem && (
              <div class="use-case__section">
                <span class="use-case__label">The Problem</span>
                <p class="use-case__text">{uc.problem}</p>
              </div>
            )}
            {uc.solution && (
              <div class="use-case__section">
                <span class="use-case__label use-case__label--solution">The Solution</span>
                <p class="use-case__text">{uc.solution}</p>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </Container>
</section>

<style>
  .product-use-cases {
    padding: var(--space-16) 0;
  }

  .product-use-cases__header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .product-use-cases__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }

  .product-use-cases__subtext {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    max-width: var(--container-sm);
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .product-use-cases__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: 48rem;
    margin: 0 auto;
  }

  .use-case {
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--duration-fast);
  }

  .use-case:hover {
    border-color: var(--color-primary-500);
  }

  .use-case__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-neutral-50);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .use-case__number {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary-500);
    color: var(--color-neutral-0);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
  }

  .use-case__title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    margin: 0;
  }

  .use-case__body {
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .use-case__section {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .use-case__label {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-neutral-500);
  }

  .use-case__label--solution {
    color: var(--color-primary-600);
  }

  .use-case__text {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-neutral-600);
    margin: 0;
  }

  @media (min-width: 768px) {
    .product-use-cases {
      padding: var(--space-20) 0;
    }
    .product-use-cases__heading {
      font-size: var(--text-4xl);
    }
    .use-case__title {
      font-size: var(--text-lg);
    }
  }
</style>
