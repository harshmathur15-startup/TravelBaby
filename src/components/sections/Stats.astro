---
import { STATS_CONTENT } from '@config';
---

<section class="stats" aria-label="Key performance metrics">
  <div class="stats__inner">
    <div class="stats__grid" role="list">
      {STATS_CONTENT.map((stat) => (
        <div class="stats__item" role="listitem">
          <span class="stats__value">{stat.value}</span>
          <span class="stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    padding: 4rem 1.5rem;
    background: var(--color-bg-alt, #f9fafb);
    border-top: 1px solid var(--color-border, #e5e7eb);
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .stats__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stats__value {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--color-primary, #2563eb);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stats__label {
    font-size: 0.9375rem;
    color: var(--color-text-secondary, #6b7280);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .stats {
      padding: 3rem 1.5rem;
    }

    .stats__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
