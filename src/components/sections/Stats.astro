---
import { STATS_CONTENT } from '@config';
---

<section class="stats" aria-label="Key performance metrics">
  <div class="stats__inner">
    <div class="stats__grid" role="list">
      {STATS_CONTENT.map((stat, index) => (
        <div class="stats__item" role="listitem" data-animate="fade-up" style={`--delay: ${index * 100}ms`}>
          <span class="stats__value">{stat.value}</span>
          <span class="stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    padding: var(--space-12) var(--space-6);
    background:
      radial-gradient(at 20% 30%, var(--color-primary-100) 0%, transparent 50%),
      radial-gradient(at 80% 70%, var(--color-accent-100) 0%, transparent 50%),
      var(--color-neutral-50);
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .stats__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px) saturate(1.5);
    -webkit-backdrop-filter: blur(12px) saturate(1.5);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius-xl);
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .stats__item:hover {
    transform: translateY(-2px);
  }

  .stats__value {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-500);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
  }

  .stats__label {
    font-size: var(--text-base);
    color: var(--color-neutral-600);
    font-weight: var(--font-weight-medium);
  }

  @media (max-width: 768px) {
    .stats__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .stats { padding: var(--space-8) var(--space-6); }
    .stats__grid { grid-template-columns: 1fr; gap: var(--space-6); }
  }
</style>
