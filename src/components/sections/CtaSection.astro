---
import { CTA_CONTENT } from '@config';
---

<section class="cta-section" aria-labelledby="cta-heading">
  <div class="cta-section__inner">
    <h2 id="cta-heading" class="cta-section__heading">{CTA_CONTENT.heading}</h2>
    <p class="cta-section__subtext">
      {CTA_CONTENT.subtext}
    </p>
    <a
      href={CTA_CONTENT.buttonHref}
      class="cta-section__btn"
      aria-label={CTA_CONTENT.buttonLabel}
    >
      {CTA_CONTENT.buttonLabel}
    </a>
  </div>
</section>

<style>
  .cta-section {
    padding: var(--space-20) var(--space-6);
    background: linear-gradient(
      135deg,
      var(--color-primary-700) 0%,
      var(--color-primary-900) 40%,
      var(--color-primary-950) 70%,
      var(--color-accent-900) 100%
    );
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(255,255,255,0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .cta-section__inner {
    max-width: var(--container-md);
    margin: 0 auto;
    position: relative;
  }

  .cta-section__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-0);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }

  .cta-section__subtext {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-8);
  }

  .cta-section__btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-10);
    background: var(--color-neutral-0);
    color: var(--color-primary-700);
    font-size: var(--text-base);
    font-weight: var(--font-weight-bold);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: transform var(--duration-fast), box-shadow var(--duration-fast);
  }

  .cta-section__btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
  }

  @media (min-width: 768px) {
    .cta-section__heading { font-size: var(--text-4xl); }
  }

  @media (max-width: 640px) {
    .cta-section { padding: var(--space-12) var(--space-6); }
  }
</style>
