---
/**
 * ComparisonCell — renders a boolean checkmark/X or text badge for comparison tables.
 * SECURITY: set:html used below is safe — all SVG values are hardcoded strings.
 */

import type { CellValue } from '@lib/comparison-utils'

interface Props {
  value: CellValue
}

const { value } = Astro.props

const CHECK_SVG =
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="20" height="20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>'

const X_SVG =
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="20" height="20" aria-hidden="true"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>'

const html = value === true ? CHECK_SVG : value === false ? X_SVG : value
const cssClass = value === true ? 'cell--yes' : value === false ? 'cell--no' : 'cell--text'
const label = value === true ? 'Yes' : value === false ? 'No' : value
---

<span class={`cell ${cssClass}`} aria-label={label} set:html={html} />
