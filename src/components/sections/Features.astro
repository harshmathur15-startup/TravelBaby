---
import { FEATURES_CONTENT } from '@config';
---

<section class="features" id="features" aria-labelledby="features-heading">
  <div class="features__inner">
    <div class="features__header">
      <span class="features__eyebrow">{FEATURES_CONTENT.eyebrow}</span>
      <h2 id="features-heading" class="features__heading">{FEATURES_CONTENT.heading}</h2>
      <p class="features__subtext">
        {FEATURES_CONTENT.subtext}
      </p>
    </div>

    <div class="features__grid" role="list">
      {FEATURES_CONTENT.items.map((feature) => (
        <div class="features__card" role="listitem">
          <div class="features__icon" aria-hidden="true" set:html={feature.icon} />
          <h3 class="features__title">{feature.title}</h3>
          <p class="features__description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 5rem 1.5rem;
    background: var(--color-bg, #fff);
  }

  .features__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .features__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .features__eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary, #2563eb);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .features__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--color-text, #111827);
    letter-spacing: -0.025em;
    margin: 0 0 1rem;
  }

  .features__subtext {
    font-size: 1.125rem;
    color: var(--color-text-secondary, #6b7280);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .features__card {
    padding: 2rem;
    background: var(--color-bg-alt, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .features__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .features__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: 1.25rem;
    background: var(--color-primary-light, #eff6ff);
    color: var(--color-primary, #2563eb);
    border-radius: 0.75rem;
  }

  .features__title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    margin: 0 0 0.5rem;
  }

  .features__description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary, #6b7280);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features {
      padding: 3.5rem 1.5rem;
    }

    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
