---
import { FEATURES_CONTENT } from '@config';
---

<section class="features" id="features" aria-labelledby="features-heading">
  <div class="features__inner">
    <div class="features__header">
      <span class="features__eyebrow">{FEATURES_CONTENT.eyebrow}</span>
      <h2 id="features-heading" class="features__heading">{FEATURES_CONTENT.heading}</h2>
      <p class="features__subtext">
        {FEATURES_CONTENT.subtext}
      </p>
    </div>

    <div class="features__grid" role="list">
      {FEATURES_CONTENT.items.map((feature, index) => (
        <div class="features__card" role="listitem" data-animate="fade-up" style={`--delay: ${index * 100}ms`}>
          <div class="features__icon" aria-hidden="true" set:html={feature.icon} />
          <h3 class="features__title">{feature.title}</h3>
          <p class="features__description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-20) var(--space-6);
    background:
      radial-gradient(at 10% 50%, var(--color-primary-50) 0%, transparent 40%),
      radial-gradient(at 90% 30%, var(--color-accent-50) 0%, transparent 40%),
      var(--color-neutral-0);
  }

  .features__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .features__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .features__eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .features__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }

  .features__subtext {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .features__card {
    padding: var(--space-8);
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(8px) saturate(1.3);
    -webkit-backdrop-filter: blur(8px) saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius-xl);
    transition: transform var(--duration-fast), box-shadow var(--duration-fast), background var(--duration-fast);
  }

  .features__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    background: rgba(255, 255, 255, 0.8);
  }

  .features__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-5);
    background: var(--color-primary-50);
    color: var(--color-primary-500);
    border-radius: var(--radius-lg);
  }

  .features__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    margin: 0 0 var(--space-2);
  }

  .features__description {
    font-size: var(--text-base);
    color: var(--color-neutral-600);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  @media (min-width: 768px) {
    .features__heading { font-size: var(--text-4xl); }
  }

  @media (max-width: 1024px) {
    .features__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .features { padding: var(--space-12) var(--space-6); }
    .features__grid { grid-template-columns: 1fr; }
  }
</style>
