---
/**
 * TeamGrid — team member cards with avatar placeholders.
 * Generic section for displaying team members on About or similar pages.
 */

import Card from '@components/ui/Card.astro';

interface TeamMember {
  name: string;
  role: string;
  image?: string;
  bio?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  members: TeamMember[];
}

const { eyebrow, heading, subtext, members } = Astro.props;
---

<section class="team-grid" aria-labelledby={heading ? 'team-grid-heading' : undefined}>
  <div class="team-grid__inner">
    {(eyebrow || heading || subtext) && (
      <div class="team-grid__header">
        {eyebrow && <span class="team-grid__eyebrow">{eyebrow}</span>}
        {heading && <h2 id="team-grid-heading" class="team-grid__heading">{heading}</h2>}
        {subtext && <p class="team-grid__subtext">{subtext}</p>}
      </div>
    )}

    <div class="team-grid__cards" role="list">
      {members.map((member, index) => (
        <Card padding="md" class="team-grid__card" data-animate="scale-in" style={`--delay: ${index * 100}ms`}>
          <div role="listitem" class="team-grid__card-inner">
            {member.image ? (
              <img
                src={member.image}
                alt={member.name}
                width="96"
                height="96"
                class="team-grid__avatar-img"
                loading="lazy"
              />
            ) : (
              <div class="team-grid__avatar" aria-hidden="true">
                <span class="team-grid__initial">{member.name.charAt(0)}</span>
              </div>
            )}
            <h3 class="team-grid__name">{member.name}</h3>
            <p class="team-grid__role">{member.role}</p>
            {member.bio && <p class="team-grid__bio">{member.bio}</p>}
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>

<style>
  .team-grid {
    padding: var(--space-20) var(--space-6);
    background: var(--color-neutral-0);
  }

  .team-grid__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .team-grid__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .team-grid__eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .team-grid__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-950);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
  }

  .team-grid__subtext {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .team-grid__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  .team-grid__card-inner {
    text-align: center;
  }

  .team-grid__avatar-img {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    object-fit: cover;
    margin: 0 auto var(--space-4);
    border: 3px solid var(--color-primary-100);
  }

  .team-grid__avatar {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary-100);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-4);
  }

  .team-grid__initial {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary-600);
  }

  .team-grid__name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    margin-bottom: var(--space-1);
  }

  .team-grid__role {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    margin: 0;
  }

  .team-grid__bio {
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    line-height: var(--leading-relaxed);
    margin: var(--space-3) 0 0;
  }

  @media (min-width: 768px) {
    .team-grid__heading { font-size: var(--text-4xl); }
    .team-grid__cards { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .team-grid__avatar-img {
      width: 96px;
      height: 96px;
    }

    .team-grid__avatar {
      width: 96px;
      height: 96px;
    }

    .team-grid__initial {
      font-size: var(--text-3xl);
    }
  }

  @media (max-width: 640px) {
    .team-grid { padding: var(--space-12) var(--space-6); }
  }
</style>
