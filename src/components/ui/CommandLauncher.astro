---
/**
 * CommandLauncher — Cmd+K / Ctrl+K keyboard-driven search overlay.
 * Leverages Pagefind for search results. Closes on Escape or backdrop click.
 * Place in BaseLayout (renders hidden, activates on keyboard shortcut).
 */

import { SITE_CONFIG } from '@config';

const navLinks = SITE_CONFIG.navLinks ?? [];
---

<div id="cmd-launcher" class="cmd-launcher" role="dialog" aria-modal="true" aria-label="Quick navigation" aria-hidden="true">
  <div class="cmd-launcher__backdrop" data-close></div>
  <div class="cmd-launcher__panel">
    <div class="cmd-launcher__search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="cmd-launcher__search-icon">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="cmd-launcher-input"
        type="search"
        class="cmd-launcher__input"
        placeholder="Search pages, posts, or type a URL..."
        autocomplete="off"
        aria-label="Search"
      />
      <kbd class="cmd-launcher__kbd" aria-hidden="true">Esc</kbd>
    </div>

    <div class="cmd-launcher__results" role="listbox" aria-label="Results">
      <!-- Quick links (shown when input is empty) -->
      <div class="cmd-launcher__section cmd-launcher__quick-links">
        <p class="cmd-launcher__section-label">Quick Links</p>
        {navLinks.map((link) => (
          <a href={link.href} class="cmd-launcher__item" role="option">
            <span class="cmd-launcher__item-label">{link.label}</span>
            <span class="cmd-launcher__item-hint">{link.href}</span>
          </a>
        ))}
      </div>

      <!-- Search results (shown when input has text) -->
      <div class="cmd-launcher__section cmd-launcher__search-results" style="display:none">
        <p class="cmd-launcher__section-label">Search Results</p>
        <div id="cmd-launcher-results"></div>
      </div>

      <div class="cmd-launcher__empty" style="display:none">
        <p>No results found.</p>
      </div>
    </div>

    <div class="cmd-launcher__footer">
      <span><kbd>↑↓</kbd> Navigate</span>
      <span><kbd>↵</kbd> Open</span>
      <span><kbd>Esc</kbd> Close</span>
    </div>
  </div>
</div>

<style>
  .cmd-launcher {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 20vh;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-fast), visibility var(--duration-fast);
  }

  .cmd-launcher[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .cmd-launcher__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .cmd-launcher__panel {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin: 0 var(--space-4);
    background: var(--color-neutral-0);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
  }

  .cmd-launcher__search {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-neutral-100);
  }

  .cmd-launcher__search-icon {
    color: var(--color-neutral-400);
    flex-shrink: 0;
  }

  .cmd-launcher__input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: var(--text-base);
    color: var(--color-neutral-900);
  }

  .cmd-launcher__input::placeholder {
    color: var(--color-neutral-400);
  }

  .cmd-launcher__kbd {
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-family: var(--font-mono, monospace);
    color: var(--color-neutral-400);
    background: var(--color-neutral-100);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-sm);
    line-height: 1;
  }

  .cmd-launcher__results {
    max-height: 320px;
    overflow-y: auto;
    padding: var(--space-2);
  }

  .cmd-launcher__section-label {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-400);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  .cmd-launcher__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-neutral-700);
    transition: background var(--duration-fast);
    cursor: pointer;
  }

  .cmd-launcher__item:hover,
  .cmd-launcher__item.is-active {
    background: var(--color-primary-50);
    color: var(--color-primary-700);
  }

  .cmd-launcher__item-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
  }

  .cmd-launcher__item-hint {
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
  }

  .cmd-launcher__empty {
    padding: var(--space-8);
    text-align: center;
    color: var(--color-neutral-400);
    font-size: var(--text-sm);
  }

  .cmd-launcher__footer {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-top: 1px solid var(--color-neutral-100);
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
  }

  .cmd-launcher__footer kbd {
    padding: 1px 4px;
    font-family: var(--font-mono, monospace);
    background: var(--color-neutral-100);
    border: 1px solid var(--color-neutral-200);
    border-radius: 3px;
    font-size: 10px;
  }

  @media (max-width: 640px) {
    .cmd-launcher { padding-top: 10vh; }
    .cmd-launcher__panel { max-width: 100%; margin: 0 var(--space-2); }
    .cmd-launcher__footer { display: none; }
  }
</style>

<script is:inline>
  (function() {
    var launcher = document.getElementById('cmd-launcher');
    var input = document.getElementById('cmd-launcher-input');
    var quickLinks = launcher && launcher.querySelector('.cmd-launcher__quick-links');
    var searchResults = launcher && launcher.querySelector('.cmd-launcher__search-results');
    var emptyState = launcher && launcher.querySelector('.cmd-launcher__empty');
    var resultsContainer = document.getElementById('cmd-launcher-results');
    var pagefind = null;
    var activeIndex = -1;
    var debounceTimer;

    function open() {
      if (launcher) launcher.setAttribute('aria-hidden', 'false');
      if (input) input.focus();
      document.body.style.overflow = 'hidden';
    }

    function close() {
      if (launcher) launcher.setAttribute('aria-hidden', 'true');
      if (input) input.value = '';
      document.body.style.overflow = '';
      activeIndex = -1;
      showQuickLinks();
    }

    function showQuickLinks() {
      if (quickLinks) quickLinks.style.display = '';
      if (searchResults) searchResults.style.display = 'none';
      if (emptyState) emptyState.style.display = 'none';
    }

    function showSearchResults() {
      if (quickLinks) quickLinks.style.display = 'none';
      if (searchResults) searchResults.style.display = '';
    }

    document.addEventListener('keydown', function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        var isOpen = launcher && launcher.getAttribute('aria-hidden') === 'false';
        isOpen ? close() : open();
      }
      if (e.key === 'Escape' && launcher && launcher.getAttribute('aria-hidden') === 'false') {
        close();
      }
    });

    var backdrop = launcher && launcher.querySelector('[data-close]');
    if (backdrop) backdrop.addEventListener('click', close);

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        if (pagefind.init) await pagefind.init();
        return pagefind;
      } catch(e) {
        return null;
      }
    }

    if (input) {
      input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var query = input.value.trim();
        if (!query) { showQuickLinks(); return; }

        debounceTimer = setTimeout(async function() {
          var pf = await loadPagefind();
          if (!pf || !resultsContainer) return;

          var search = await pf.search(query);
          if (search.results.length === 0) {
            showSearchResults();
            resultsContainer.innerHTML = '';
            if (emptyState) emptyState.style.display = '';
            return;
          }

          if (emptyState) emptyState.style.display = 'none';
          showSearchResults();

          var top5 = search.results.slice(0, 5);
          var items = await Promise.all(top5.map(function(r) { return r.data(); }));

          resultsContainer.innerHTML = items.map(function(item) {
            return '<a href="' + item.url + '" class="cmd-launcher__item" role="option">' +
              '<span class="cmd-launcher__item-label">' + item.meta.title + '</span>' +
              '<span class="cmd-launcher__item-hint">' + item.url + '</span></a>';
          }).join('');
          activeIndex = -1;
        }, 200);
      });

      input.addEventListener('keydown', function(e) {
        var items = launcher ? launcher.querySelectorAll('.cmd-launcher__item') : [];
        if (!items.length) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = Math.min(activeIndex + 1, items.length - 1);
          items.forEach(function(el, i) { el.classList.toggle('is-active', i === activeIndex); });
          items[activeIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = Math.max(activeIndex - 1, 0);
          items.forEach(function(el, i) { el.classList.toggle('is-active', i === activeIndex); });
          items[activeIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter' && activeIndex >= 0 && items[activeIndex]) {
          e.preventDefault();
          items[activeIndex].click();
        }
      });
    }
  })();
</script>
