---
/**
 * Badge — colored inline label/tag.
 * Variants: default, primary, success, warning, error, accent.
 */

interface Props {
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'error' | 'accent';
  class?: string;
}

const {
  variant = 'default',
  class: className = '',
} = Astro.props;

const variantStyles: Record<string, string> = {
  default: 'bg-[var(--color-neutral-100)] text-[var(--color-neutral-800)]',
  primary: 'bg-[var(--color-primary-50)] text-[var(--color-primary-600)]',
  success: 'bg-[var(--color-success-light)] text-[var(--color-success-dark)]',
  warning: 'bg-[var(--color-warning-light)] text-[var(--color-warning-dark)]',
  error: 'bg-[var(--color-error-light)] text-[var(--color-error-dark)]',
  accent: 'bg-[var(--color-accent-50)] text-[var(--color-accent-700)]',
};

const classes = [
  'inline-flex items-center',
  'text-[var(--text-xs)] font-medium leading-none',
  'px-[var(--space-2)] py-[var(--space-1)]',
  'rounded-[var(--radius-full)]',
  variantStyles[variant],
  className,
].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
</span>
