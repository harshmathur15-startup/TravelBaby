---
/**
 * LanguagePicker — locale switcher dropdown.
 * Reads current locale from Astro and links to alternate versions.
 */

import { getLocale, getAlternateLocales, type Locale } from '@lib/i18n';

const currentLocale = getLocale(Astro.currentLocale);
const alternates = getAlternateLocales(currentLocale, Astro.url.pathname);

const localeLabels: Record<Locale, string> = {
  en: 'EN',
  es: 'ES',
};
---

{alternates.length > 0 && (
  <div class="lang-picker">
    <span class="lang-picker__current" aria-label="Current language">{localeLabels[currentLocale]}</span>
    {alternates.map(({ locale, href }) => (
      <a href={href} class="lang-picker__link" hreflang={locale} aria-label={`Switch to ${locale}`}>
        {localeLabels[locale]}
      </a>
    ))}
  </div>
)}

<style>
  .lang-picker {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
  }

  .lang-picker__current {
    padding: var(--space-1) var(--space-2);
    color: var(--color-primary-600);
    background: var(--color-primary-50);
    border-radius: var(--radius-sm);
  }

  .lang-picker__link {
    padding: var(--space-1) var(--space-2);
    color: var(--color-neutral-500);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--duration-fast), background var(--duration-fast);
  }

  .lang-picker__link:hover {
    color: var(--color-neutral-700);
    background: var(--color-neutral-100);
  }
</style>
