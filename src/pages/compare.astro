---
/**
 * Compare page — feature comparison against competitors.
 * Content is config-driven via pages.ts. Comparison table accepts props.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import ComparisonTable from '@components/sections/ComparisonTable.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import { COMPARE_PAGE } from '@config';

const { hero, primaryCta, secondaryCta, whyUs } = COMPARE_PAGE;
---

<BaseLayout
  title="Compare"
  description={hero.subtext}
>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <Container>
      <div class="hero__inner">
        <SectionHeading
          id="hero-heading"
          eyebrow={hero.eyebrow}
          heading={hero.heading}
          subtext={hero.subtext}
          headingTag="h1"
        />
        <div class="hero__ctas">
          <a href={primaryCta.href} class="hero__btn hero__btn--primary">{primaryCta.label}</a>
          <a href={secondaryCta.href} class="hero__btn hero__btn--ghost">{secondaryCta.label}</a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Feature Comparison Table -->
  <ComparisonTable />

  <!-- Why Choose Us -->
  <section class="why" aria-labelledby="why-heading">
    <Container>
      <SectionHeading
        id="why-heading"
        eyebrow={whyUs.eyebrow}
        heading={whyUs.heading}
        subtext={whyUs.subtext}
        headingTag="h2"
      />

      <div class="why__grid">
        {whyUs.items.map((d) => (
          <div class="why__card">
            <h3 class="why__title">{d.title}</h3>
            <p class="why__desc">{d.description}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <CtaSection />
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-neutral-0) 100%);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-in-out),
                color var(--duration-fast) var(--ease-in-out);
  }

  .hero__btn--primary {
    background: var(--color-primary-500);
    color: #fff;
  }

  .hero__btn--primary:hover {
    background: var(--color-primary-600);
    color: #fff;
  }

  .hero__btn--ghost {
    background: transparent;
    color: var(--color-primary-600);
    border: 1px solid var(--color-primary-200);
  }

  .hero__btn--ghost:hover {
    background: var(--color-primary-50);
  }

  .why {
    padding: var(--space-16) 0;
    background-color: var(--color-neutral-0);
  }

  .why__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-top: var(--space-10);
  }

  .why__card {
    padding: var(--space-6);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    background-color: var(--color-neutral-0);
    transition: box-shadow var(--duration-normal) var(--ease-in-out);
  }

  .why__card:hover {
    box-shadow: var(--shadow-lg);
  }

  .why__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-neutral-950);
    margin: 0 0 var(--space-2);
  }

  .why__desc {
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  @media (min-width: 640px) {
    .why__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .hero {
      padding: var(--space-20) 0 var(--space-16);
    }

    .why {
      padding: var(--space-20) 0;
    }
  }
</style>
