---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
import Features from '../components/sections/Features.astro';
import Stats from '../components/sections/Stats.astro';
import CtaSection from '../components/sections/CtaSection.astro';
---

<BaseLayout title="Features" description="Everything you need to build and launch your website fast.">
  <section class="features-hero" aria-labelledby="features-hero-heading">
    <Container>
      <div class="features-hero__inner">
        <SectionHeading
          title="Everything You Need to Ship Fast"
          subtitle="A complete foundation with design system, CMS, SEO, and responsive components."
          as="h1"
        />
        <div class="features-hero__actions">
          <Button variant="primary" size="lg" href="/get-started">
            Get Started
          </Button>
          <Button variant="ghost" size="lg" href="#features">
            Explore Features
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <div id="features">
    <Features />
  </div>
  <Stats />
  <CtaSection />
</BaseLayout>

<style>
  .features-hero {
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-neutral-0) 100%);
  }
  .features-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }
  .features-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  @media (min-width: 768px) {
    .features-hero {
      padding: var(--space-20) 0 var(--space-16);
    }
  }
</style>
