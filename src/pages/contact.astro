---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Input from '@components/ui/Input.astro';
import Button from '@components/ui/Button.astro';
import { CONTACT_PAGE, SITE_CONFIG } from '@config';

const { hero, sidebar, form } = CONTACT_PAGE;
const { legal, socialLinks } = SITE_CONFIG;
---

<BaseLayout title="Contact Us" description={hero.subtitle}>
  <section class="contact-hero" aria-labelledby="contact-hero-heading">
    <Container>
      <div class="contact-hero__inner">
        <SectionHeading
          title={hero.title}
          subtitle={hero.subtitle}
          as="h1"
        />
      </div>
    </Container>
  </section>

  <section class="contact-content" aria-label="Contact form and information">
    <Container>
      <div class="contact-grid">
        <!-- Form -->
        <div class="contact-form-wrapper">
          <form class="contact-form" method="POST" action={form.actionUrl}>
            <input type="hidden" name="_subject" value="New Contact — Travel Baby" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://travelbaby.in/contact" />
            <div class="contact-form__row">
              <Input label="First Name" name="firstName" placeholder="Jane" required />
              <Input label="Last Name" name="lastName" placeholder="Smith" required />
            </div>
            <Input label="Email" name="email" type="email" placeholder="jane@example.com" required />
            <Input label="Phone" name="phone" type="tel" placeholder="(555) 000-0000" />
            <div class="contact-form__textarea-group">
              <label for="message" class="contact-form__label">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell us how we can help..."
                required
                class="contact-form__textarea"
              ></textarea>
            </div>
            <Button variant="primary" size="lg" type="submit">
              {form.submitLabel}
            </Button>
            <div id="form-status" class="form-status" aria-live="polite" role="status"></div>
          </form>
          <script>
            const form = document.querySelector('.contact-form') as HTMLFormElement | null;
            const status = document.getElementById('form-status');
            form?.addEventListener('submit', (e) => {
              if (status) {
                status.textContent = 'Sending message...';
                status.className = 'form-status form-status--sending';
              }
            });
          </script>
        </div>

        <!-- Sidebar -->
        <aside class="contact-sidebar">
          <div class="contact-info">
            <h2 class="contact-info__title">{sidebar.title}</h2>
            <p class="contact-info__text">{sidebar.text}</p>

            <div class="contact-info__items">
              <div class="contact-info__item">
                <div class="contact-info__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div>
                  <p class="contact-info__label">Email</p>
                  <a href={`mailto:${legal.email}`} class="contact-info__link">{legal.email}</a>
                </div>
              </div>

              <div class="contact-info__item">
                <div class="contact-info__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <p class="contact-info__label">Phone</p>
                  <a href={`tel:${legal.phone}`} class="contact-info__link">{legal.phone}</a>
                </div>
              </div>

              <div class="contact-info__item">
                <div class="contact-info__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <p class="contact-info__label">Address</p>
                  <p class="contact-info__address">{legal.address}</p>
                </div>
              </div>
            </div>

            <div class="contact-info__social">
              {socialLinks.map((link) => (
                <a href={link.href} class="contact-info__social-link" aria-label={link.label}>
                  <Fragment set:html={link.icon} />
                </a>
              ))}
            </div>

            <div class="contact-info__location">
              <p>{sidebar.locationLine}</p>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-neutral-0) 100%);
  }
  .contact-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .contact-content {
    padding: var(--space-12) 0 var(--space-16);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  /* Form */
  .contact-form-wrapper {
    background: var(--color-neutral-0);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  .contact-form__textarea-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .contact-form__label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-neutral-700);
  }
  .contact-form__textarea {
    width: 100%;
    padding: var(--space-3);
    border: 1px solid var(--color-neutral-300);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-neutral-900);
    background: var(--color-neutral-0);
    resize: vertical;
    font-family: inherit;
    transition: border-color 0.15s ease;
  }
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
  }
  .contact-form__textarea::placeholder {
    color: var(--color-neutral-400);
  }

  .form-status {
    font-size: var(--text-sm);
    padding: var(--space-2) 0;
    min-height: 1.5em;
  }
  .form-status--sending {
    color: var(--color-primary-600);
  }

  /* Sidebar */
  .contact-sidebar {
    order: -1;
  }
  .contact-info {
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }
  .contact-info__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-3);
  }
  .contact-info__text {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-6);
  }
  .contact-info__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }
  .contact-info__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .contact-info__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--color-primary-100);
    color: var(--color-primary-600);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-info__label {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }
  .contact-info__link {
    font-size: var(--text-sm);
    color: var(--color-primary-600);
    text-decoration: none;
    font-weight: 500;
  }
  .contact-info__link:hover {
    text-decoration: underline;
  }
  .contact-info__address {
    font-size: var(--text-sm);
    color: var(--color-neutral-700);
    line-height: 1.6;
  }
  .contact-info__social {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-neutral-200);
  }
  .contact-info__social-link {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--color-neutral-200);
    color: var(--color-neutral-600);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .contact-info__social-link:hover {
    background: var(--color-primary-600);
    color: white;
  }
  .contact-info__location {
    padding: var(--space-4);
    background: var(--color-primary-50);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .contact-info__location p {
    font-size: var(--text-sm);
    color: var(--color-primary-700);
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .contact-form__row {
      grid-template-columns: 1fr 1fr;
    }
    .contact-grid {
      grid-template-columns: 1fr 380px;
    }
    .contact-sidebar {
      order: 0;
    }
  }
  @media (min-width: 1024px) {
    .contact-hero {
      padding: var(--space-20) 0 var(--space-16);
    }
  }
</style>
