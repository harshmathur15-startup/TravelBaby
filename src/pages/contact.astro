---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Input from '@components/ui/Input.astro';
import Button from '@components/ui/Button.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with our team. We would love to hear from you.">
  <section class="contact-hero" aria-labelledby="contact-hero-heading">
    <Container>
      <div class="contact-hero__inner">
        <SectionHeading
          title="Contact Us"
          subtitle="Have a question, feedback, or just want to say hello? We would love to hear from you."
          as="h1"
        />
      </div>
    </Container>
  </section>

  <section class="contact-content" aria-label="Contact form and information">
    <Container>
      <div class="contact-grid">
        <!-- Form -->
        <div class="contact-form-wrapper">
          <!-- TODO: Connect to your form handler (e.g., Formspree, Netlify Forms, or your API) -->
          <form class="contact-form" method="post" action="https://formspree.io/f/your-form-id" novalidate>
            <div class="contact-form__row">
              <Input label="First Name" name="firstName" placeholder="Jane" required />
              <Input label="Last Name" name="lastName" placeholder="Smith" required />
            </div>
            <Input label="Email" name="email" type="email" placeholder="jane@example.com" required />
            <Input label="Phone" name="phone" type="tel" placeholder="(555) 000-0000" />
            <div class="contact-form__textarea-group">
              <label for="message" class="contact-form__label">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell us how we can help..."
                required
                class="contact-form__textarea"
              ></textarea>
            </div>
            <Button variant="primary" size="lg" type="submit">
              Send Message
            </Button>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="contact-sidebar">
          <div class="contact-info">
            <h2 class="contact-info__title">Get in Touch</h2>
            <p class="contact-info__text">
              Whether you have a question about features, pricing, or anything else, our team is ready to answer.
            </p>

            <div class="contact-info__items">
              <div class="contact-info__item">
                <div class="contact-info__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div>
                  <p class="contact-info__label">Email</p>
                  <a href="mailto:hello@example.com" class="contact-info__link">hello@example.com</a>
                </div>
              </div>

              <div class="contact-info__item">
                <div class="contact-info__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <p class="contact-info__label">Phone</p>
                  <a href="tel:+15550000000" class="contact-info__link">(555) 000-0000</a>
                </div>
              </div>

              <div class="contact-info__item">
                <div class="contact-info__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <p class="contact-info__label">Address</p>
                  <p class="contact-info__address">123 Main Street, Suite 100<br />Your City, ST 00000</p>
                </div>
              </div>
            </div>

            <div class="contact-info__social">
              <a href="#" class="contact-info__social-link" aria-label="LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="#" class="contact-info__social-link" aria-label="X">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            </div>

            <div class="contact-info__location">
              <p>Based in Your City — serving customers everywhere.</p>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-neutral-0) 100%);
  }
  .contact-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .contact-content {
    padding: var(--space-12) 0 var(--space-16);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  /* Form */
  .contact-form-wrapper {
    background: var(--color-neutral-0);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  .contact-form__textarea-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .contact-form__label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-neutral-700);
  }
  .contact-form__textarea {
    width: 100%;
    padding: var(--space-3);
    border: 1px solid var(--color-neutral-300);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-neutral-900);
    background: var(--color-neutral-0);
    resize: vertical;
    font-family: inherit;
    transition: border-color 0.15s ease;
  }
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
  }
  .contact-form__textarea::placeholder {
    color: var(--color-neutral-400);
  }

  /* Sidebar */
  .contact-sidebar {
    order: -1;
  }
  .contact-info {
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }
  .contact-info__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-3);
  }
  .contact-info__text {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-6);
  }
  .contact-info__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }
  .contact-info__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .contact-info__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--color-primary-100);
    color: var(--color-primary-600);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-info__label {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }
  .contact-info__link {
    font-size: var(--text-sm);
    color: var(--color-primary-600);
    text-decoration: none;
    font-weight: 500;
  }
  .contact-info__link:hover {
    text-decoration: underline;
  }
  .contact-info__address {
    font-size: var(--text-sm);
    color: var(--color-neutral-700);
    line-height: 1.6;
  }
  .contact-info__social {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-neutral-200);
  }
  .contact-info__social-link {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--color-neutral-200);
    color: var(--color-neutral-600);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .contact-info__social-link:hover {
    background: var(--color-primary-600);
    color: white;
  }
  .contact-info__location {
    padding: var(--space-4);
    background: var(--color-primary-50);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .contact-info__location p {
    font-size: var(--text-sm);
    color: var(--color-primary-700);
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .contact-form__row {
      grid-template-columns: 1fr 1fr;
    }
    .contact-grid {
      grid-template-columns: 1fr 380px;
    }
    .contact-sidebar {
      order: 0;
    }
  }
  @media (min-width: 1024px) {
    .contact-hero {
      padding: var(--space-20) 0 var(--space-16);
    }
  }
</style>
