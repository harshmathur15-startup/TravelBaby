---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import CtaSection from '@components/sections/CtaSection.astro';
---

<BaseLayout
  title="Astro Travel — Your Stars Know Where to Go | Travel Baby"
  description="Enter your birth details and let AI-powered astrology reveal your perfect travel destinations."
>
  <!-- Hero + Form -->
  <section class="at-hero" aria-labelledby="at-hero-heading">
    <div class="at-stars" aria-hidden="true"></div>
    <Container size="sm">
      <div class="at-hero__inner">
        <p class="at-hero__eyebrow">✨ Astro Travel by Travel Baby</p>
        <h1 id="at-hero-heading" class="at-hero__title">
          Your Stars Know<br />Where to Go
        </h1>
        <p class="at-hero__subtitle">
          Enter your birth details and our AI astrologer will map your cosmic travel profile — destinations, experiences, and timing written in your chart.
        </p>

        <!-- Form card -->
        <div class="at-card" id="at-form-card">
          <form id="at-form" class="at-form" novalidate>
            <div class="at-form__grid">
              <div class="at-field">
                <label for="dob" class="at-field__label">Date of Birth</label>
                <input type="date" id="dob" name="dob" required class="at-field__input" />
              </div>
              <div class="at-field">
                <label for="tob" class="at-field__label">Time of Birth</label>
                <input type="time" id="tob" name="tob" required class="at-field__input" />
                <p class="at-field__hint">From your birth certificate if possible</p>
              </div>
            </div>
            <div class="at-form__grid">
              <div class="at-field">
                <label for="at-country" class="at-field__label">Country of Birth</label>
                <select id="at-country" name="country" required class="at-field__input at-field__select">
                  <option value="">Select country…</option>
                </select>
              </div>
              <div class="at-field">
                <label for="at-city" class="at-field__label">City of Birth</label>
                <select id="at-city" name="city" required class="at-field__input at-field__select" disabled>
                  <option value="">Select country first…</option>
                </select>
              </div>
            </div>
            <p id="at-error" class="at-error" hidden></p>
            <button type="submit" class="at-submit" id="at-submit">
              ✨ Reveal My Cosmic Destinations
            </button>
          </form>

          <!-- Loading -->
          <div id="at-loading" class="at-loading" hidden>
            <div class="at-loading__orb" aria-hidden="true"></div>
            <p class="at-loading__text">Mapping your celestial chart…</p>
            <p class="at-loading__sub">Our AI astrologer is reading the stars</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Results -->
  <section id="at-results" class="at-results" hidden aria-label="Your astro travel reading">
    <Container>

      <!-- Profile header -->
      <div class="at-profile" id="at-profile">
        <div class="at-profile__sign" id="at-profile-sign"></div>
        <div class="at-profile__info">
          <p class="at-profile__label">Your Sign</p>
          <h2 class="at-profile__name" id="at-profile-name"></h2>
          <p class="at-profile__meta" id="at-profile-meta"></p>
        </div>
        <div class="at-profile__style">
          <p class="at-profile__label">Travel Personality</p>
          <p class="at-profile__style-name" id="at-profile-style"></p>
          <p class="at-profile__style-desc" id="at-profile-style-desc"></p>
        </div>
      </div>

      <!-- Cosmic message -->
      <blockquote class="at-cosmic-msg" id="at-cosmic-profile"></blockquote>

      <!-- Destinations -->
      <h3 class="at-section-title">Your Cosmic Destinations</h3>
      <div class="at-destinations" id="at-destinations"></div>

      <!-- Best time + avoid tip -->
      <div class="at-insights">
        <div class="at-insight-card">
          <p class="at-insight-card__icon" aria-hidden="true">📅</p>
          <h4 class="at-insight-card__title">Best Months to Travel</h4>
          <p class="at-insight-card__body" id="at-best-months"></p>
        </div>
        <div class="at-insight-card">
          <p class="at-insight-card__icon" aria-hidden="true">⚡</p>
          <h4 class="at-insight-card__title">What to Avoid</h4>
          <p class="at-insight-card__body" id="at-avoid"></p>
        </div>
      </div>

      <!-- Closing message -->
      <div class="at-closing">
        <p class="at-closing__msg" id="at-closing-msg"></p>
        <a href="/plan-my-trip" class="at-closing__cta">Plan My Cosmic Trip →</a>
        <button class="at-closing__restart" id="at-restart">Try another chart</button>
      </div>

    </Container>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  /* ── Hero ── */
  .at-hero {
    position: relative;
    min-height: 100vh;
    background: radial-gradient(ellipse at top, #1a0a3d 0%, #0a0a1a 60%, #000 100%);
    display: flex;
    align-items: center;
    padding: var(--space-20) 0 var(--space-16);
    overflow: hidden;
  }

  /* Star field */
  .at-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 40%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 40% 10%, rgba(255,255,255,0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 65%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 25%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 80% 55%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 80%, rgba(255,255,255,0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 75%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 85%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 90%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(2px 2px at 5%  30%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(2px 2px at 45% 50%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(2px 2px at 75% 70%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 20% 55%, rgba(200,180,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 65% 35%, rgba(180,200,255,0.6) 0%, transparent 100%);
    pointer-events: none;
  }

  .at-hero__inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .at-hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #c4b5fd;
    margin-bottom: var(--space-4);
  }
  .at-hero__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.15;
    color: #fff;
    margin-bottom: var(--space-5);
  }
  .at-hero__subtitle {
    font-size: var(--text-base);
    line-height: 1.7;
    color: #a8a8c8;
    max-width: 480px;
    margin: 0 auto var(--space-10);
  }
  @media (min-width: 768px) {
    .at-hero__title { font-size: var(--text-5xl); }
    .at-hero__subtitle { font-size: var(--text-lg); }
  }

  /* ── Form card ── */
  .at-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    backdrop-filter: blur(16px);
    text-align: left;
  }
  .at-form { display: flex; flex-direction: column; gap: var(--space-5); }
  .at-form__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 540px) {
    .at-form__grid { grid-template-columns: 1fr 1fr; }
  }
  .at-field { display: flex; flex-direction: column; gap: var(--space-1); }
  .at-field__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: #c4b5fd;
    letter-spacing: 0.02em;
  }
  .at-field__input {
    width: 100%;
    padding: var(--space-3);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    color: #fff;
    font-family: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
    color-scheme: dark;
  }
  .at-field__input::placeholder { color: rgba(255,255,255,0.3); }
  .at-field__input:focus {
    outline: none;
    border-color: #8b5cf6;
    box-shadow: 0 0 0 3px rgba(139,92,246,0.25);
  }
  .at-field__hint { font-size: var(--text-xs); color: rgba(255,255,255,0.35); }
  .at-field__select option { background: #1a0a3d; color: #fff; }
  .at-error { font-size: var(--text-sm); color: #f87171; text-align: center; }
  .at-submit {
    width: 100%;
    padding: var(--space-4);
    background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
    color: #fff;
    font-size: var(--text-base);
    font-weight: 700;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    transition: opacity 0.2s, transform 0.2s;
  }
  .at-submit:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
  .at-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  /* ── Loading ── */
  .at-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-10) 0;
  }
  .at-loading__orb {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #c4b5fd, #7c3aed);
    animation: orb-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 30px rgba(139,92,246,0.6);
  }
  @keyframes orb-pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 30px rgba(139,92,246,0.6); }
    50% { transform: scale(1.15); box-shadow: 0 0 50px rgba(139,92,246,0.9); }
  }
  .at-loading__text {
    font-size: var(--text-lg);
    font-weight: 600;
    color: #e2e2f0;
  }
  .at-loading__sub { font-size: var(--text-sm); color: #8888aa; }

  /* ── Results ── */
  .at-results {
    padding: var(--space-16) 0 var(--space-8);
    background: var(--color-neutral-0);
  }

  /* Profile */
  .at-profile {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-8);
    background: linear-gradient(135deg, #1a0a3d 0%, #0f0a2a 100%);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
    color: #fff;
  }
  @media (min-width: 640px) {
    .at-profile { grid-template-columns: auto 1fr 1fr; align-items: center; }
  }
  .at-profile__sign {
    font-size: 4rem;
    line-height: 1;
    text-align: center;
  }
  .at-profile__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a78bfa;
    margin-bottom: var(--space-1);
  }
  .at-profile__name {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: #fff;
    margin-bottom: var(--space-1);
  }
  .at-profile__meta { font-size: var(--text-sm); color: #c4b5fd; }
  .at-profile__style-name {
    font-size: var(--text-lg);
    font-weight: 700;
    color: #fbbf24;
    margin-bottom: var(--space-1);
  }
  .at-profile__style-desc { font-size: var(--text-sm); color: #a8a8c8; line-height: 1.5; }

  /* Cosmic message */
  .at-cosmic-msg {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-neutral-600);
    font-style: italic;
    text-align: center;
    border-left: 3px solid #7c3aed;
    padding-left: var(--space-5);
    margin: 0 0 var(--space-10);
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Section title */
  .at-section-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-6);
  }

  /* Destinations */
  .at-destinations {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }
  .at-dest-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .at-dest-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  @media (min-width: 640px) {
    .at-dest-card { grid-template-columns: auto 1fr; }
  }
  .at-dest-card__rank {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }
  .at-dest-card__num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .at-dest-card__emoji { font-size: var(--text-2xl); }
  .at-dest-card__name {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-1);
  }
  .at-dest-card__country {
    font-size: var(--text-sm);
    color: var(--color-primary-600);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }
  .at-dest-card__why {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-4);
  }
  .at-dest-card__experiences {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .at-dest-card__exp {
    font-size: var(--text-xs);
    font-weight: 600;
    color: #7c3aed;
    background: #f5f3ff;
    border: 1px solid #ddd6fe;
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
  }

  /* Insights */
  .at-insights {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }
  @media (min-width: 640px) {
    .at-insights { grid-template-columns: 1fr 1fr; }
  }
  .at-insight-card {
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .at-insight-card__icon { font-size: var(--text-2xl); margin-bottom: var(--space-3); }
  .at-insight-card__title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-2);
  }
  .at-insight-card__body { font-size: var(--text-sm); line-height: 1.65; color: var(--color-neutral-600); }

  /* Closing */
  .at-closing {
    text-align: center;
    padding: var(--space-10) 0 var(--space-4);
    border-top: 1px solid var(--color-neutral-200);
  }
  .at-closing__msg {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-neutral-700);
    margin-bottom: var(--space-6);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .at-closing__cta {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    color: #fff;
    font-weight: 700;
    border-radius: var(--radius-full);
    text-decoration: none;
    margin-bottom: var(--space-4);
    transition: opacity 0.2s, transform 0.2s;
    display: block;
    width: fit-content;
    margin: 0 auto var(--space-4);
  }
  .at-closing__cta:hover { opacity: 0.9; transform: translateY(-1px); }
  .at-closing__restart {
    display: block;
    margin: 0 auto;
    background: none;
    border: none;
    font-size: var(--text-sm);
    color: var(--color-neutral-400);
    cursor: pointer;
    font-family: inherit;
    text-decoration: underline;
    padding: var(--space-2);
    margin-top: var(--space-3);
  }
  .at-closing__restart:hover { color: var(--color-neutral-600); }
</style>

<script>
  const CITIES: Record<string, string[]> = {
    Australia: ['Adelaide', 'Brisbane', 'Melbourne', 'Perth', 'Sydney'],
    Canada: ['Calgary', 'Montreal', 'Ottawa', 'Toronto', 'Vancouver'],
    France: ['Lyon', 'Marseille', 'Nice', 'Paris'],
    Germany: ['Berlin', 'Frankfurt', 'Hamburg', 'Munich'],
    India: [
      'Ahmedabad', 'Bangalore', 'Bhopal', 'Chandigarh', 'Chennai', 'Delhi',
      'Guwahati', 'Hyderabad', 'Indore', 'Jaipur', 'Kochi', 'Kolkata',
      'Lucknow', 'Mumbai', 'Nagpur', 'Patna', 'Pune', 'Surat',
      'Vadodara', 'Varanasi', 'Visakhapatnam',
    ],
    Indonesia: ['Bali', 'Jakarta', 'Surabaya'],
    Italy: ['Florence', 'Milan', 'Rome', 'Venice'],
    Japan: ['Kyoto', 'Osaka', 'Tokyo'],
    Malaysia: ['Johor Bahru', 'Kuala Lumpur', 'Penang'],
    Nepal: ['Kathmandu', 'Pokhara'],
    Netherlands: ['Amsterdam', 'Rotterdam'],
    'New Zealand': ['Auckland', 'Christchurch', 'Wellington'],
    Portugal: ['Lisbon', 'Porto'],
    Singapore: ['Singapore'],
    'South Africa': ['Cape Town', 'Durban', 'Johannesburg'],
    Spain: ['Barcelona', 'Madrid', 'Seville'],
    'Sri Lanka': ['Colombo', 'Kandy'],
    Thailand: ['Bangkok', 'Chiang Mai', 'Phuket'],
    Turkey: ['Ankara', 'Istanbul'],
    UAE: ['Abu Dhabi', 'Dubai', 'Sharjah'],
    UK: ['Birmingham', 'Edinburgh', 'Glasgow', 'Leeds', 'London', 'Manchester'],
    USA: ['Chicago', 'Dallas', 'Houston', 'Las Vegas', 'Los Angeles', 'Miami', 'New York', 'San Francisco', 'Seattle'],
    Vietnam: ['Da Nang', 'Hanoi', 'Ho Chi Minh City'],
  };

  const countryEl = document.getElementById('at-country') as HTMLSelectElement | null;
  const cityEl = document.getElementById('at-city') as HTMLSelectElement | null;
  const form = document.getElementById('at-form') as HTMLFormElement | null;
  const loadingEl = document.getElementById('at-loading') as HTMLElement | null;
  const resultsSection = document.getElementById('at-results') as HTMLElement | null;
  const errorEl = document.getElementById('at-error') as HTMLElement | null;
  const submitBtn = document.getElementById('at-submit') as HTMLButtonElement | null;
  const formCard = document.getElementById('at-form-card') as HTMLElement | null;

  // Populate country dropdown
  if (countryEl) {
    Object.keys(CITIES).sort().forEach((country) => {
      const opt = document.createElement('option');
      opt.value = country;
      opt.textContent = country;
      countryEl.appendChild(opt);
    });
  }

  // Update cities when country changes
  countryEl?.addEventListener('change', () => {
    if (!cityEl || !countryEl) return;
    const cities = CITIES[countryEl.value] ?? [];
    cityEl.innerHTML = '';
    if (!cities.length) {
      cityEl.innerHTML = '<option value="">Select country first…</option>';
      cityEl.disabled = true;
      return;
    }
    cityEl.disabled = false;
    const placeholder = document.createElement('option');
    placeholder.value = '';
    placeholder.textContent = 'Select city…';
    cityEl.appendChild(placeholder);
    cities.forEach((city) => {
      const opt = document.createElement('option');
      opt.value = city;
      opt.textContent = city;
      cityEl.appendChild(opt);
    });
  });

  function showError(msg: string): void {
    if (errorEl) { errorEl.textContent = msg; errorEl.hidden = false; }
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '✨ Reveal My Cosmic Destinations'; }
    if (loadingEl) loadingEl.hidden = true;
    if (form) form.hidden = false;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errorEl) errorEl.hidden = true;

    const dob = (document.getElementById('dob') as HTMLInputElement).value;
    const tob = (document.getElementById('tob') as HTMLInputElement).value;
    const country = countryEl?.value ?? '';
    const city = cityEl?.value ?? '';

    if (!dob || !tob || !country || !city) {
      showError('Please fill in all fields.');
      return;
    }

    const pob = `${city}, ${country}`;

    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Reading your chart…'; }
    if (form) form.hidden = true;
    if (loadingEl) loadingEl.hidden = false;

    try {
      const res = await fetch('/api/astro-reading', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dob, tob, pob }),
      });

      const data = await res.json();
      if (!res.ok || data.error) {
        showError(data.error || 'Something went wrong. Please try again.');
        return;
      }

      const setText = (id: string, val: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
      };

      setText('at-profile-sign', data.symbol ?? '');
      setText('at-profile-name', data.sign ?? '');
      setText('at-profile-meta', `${data.element} Sign · Rising: ${data.risingSign}`);
      setText('at-profile-style', data.travelStyle ?? '');
      setText('at-profile-style-desc', data.travelStyleDesc ?? '');
      setText('at-cosmic-profile', data.cosmicProfile ?? '');
      setText('at-best-months', (data.bestMonths ?? []).join(', '));
      setText('at-avoid', data.avoidTip ?? '');
      setText('at-closing-msg', data.cosmicMessage ?? '');

      const destContainer = document.getElementById('at-destinations');
      if (destContainer && Array.isArray(data.destinations)) {
        destContainer.innerHTML = '';
        data.destinations.forEach((dest: { rank: number; emoji: string; name: string; country: string; whyItFits: string; experiences: string[] }) => {
          const card = document.createElement('div');
          card.className = 'at-dest-card';
          card.innerHTML = `
            <div class="at-dest-card__rank">
              <div class="at-dest-card__num">${dest.rank}</div>
              <span class="at-dest-card__emoji">${dest.emoji}</span>
            </div>
            <div>
              <p class="at-dest-card__name">${dest.name}</p>
              <p class="at-dest-card__country">${dest.country}</p>
              <p class="at-dest-card__why">${dest.whyItFits}</p>
              <div class="at-dest-card__experiences">
                ${dest.experiences.map((exp: string) => `<span class="at-dest-card__exp">${exp}</span>`).join('')}
              </div>
            </div>
          `;
          destContainer.appendChild(card);
        });
      }

      if (loadingEl) loadingEl.hidden = true;
      if (formCard) formCard.hidden = true;
      if (resultsSection) { resultsSection.hidden = false; resultsSection.scrollIntoView({ behavior: 'smooth' }); }

    } catch {
      showError('Network error. Please check your connection and try again.');
    }
  });

  document.getElementById('at-restart')?.addEventListener('click', () => {
    if (resultsSection) resultsSection.hidden = true;
    if (formCard) formCard.hidden = false;
    if (form) form.hidden = false;
    if (loadingEl) loadingEl.hidden = true;
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '✨ Reveal My Cosmic Destinations'; }
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
