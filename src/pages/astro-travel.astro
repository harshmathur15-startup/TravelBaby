---
import BaseLayout from '@layouts/BaseLayout.astro'
import Container from '@components/ui/Container.astro'
import CtaSection from '@components/sections/CtaSection.astro'
---

<BaseLayout
  title="Astro Travel — Your Stars Know Where to Go | Travel Baby"
  description="Enter your birth details and let AI-powered astrology reveal your perfect travel destinations."
>
  <!-- ── Step 1: Form ── -->
  <section class="at-hero" id="at-step-form" aria-labelledby="at-hero-heading">
    <div class="at-stars" aria-hidden="true"></div>
    <Container size="sm">
      <div class="at-hero__inner">
        <p class="at-hero__eyebrow">✨ Astro Travel by Travel Baby</p>
        <h1 id="at-hero-heading" class="at-hero__title">Your Stars Know<br />Where to Go</h1>
        <p class="at-hero__subtitle">
          Enter your birth details and our AI astrologer will map your perfect trip — domestic or
          international, beach or mountain, any budget.
        </p>
        <div class="at-card" id="at-form-card">
          <form id="at-form" class="at-form" novalidate>
            <div class="at-form__grid">
              <div class="at-field">
                <label for="dob" class="at-field__label">Date of Birth</label>
                <input type="date" id="dob" name="dob" required class="at-field__input" />
              </div>
              <div class="at-field">
                <label for="tob" class="at-field__label">Time of Birth</label>
                <input type="time" id="tob" name="tob" required class="at-field__input" />
                <p class="at-field__hint">From your birth certificate if possible</p>
              </div>
            </div>
            <div class="at-form__grid">
              <div class="at-field">
                <label for="at-country" class="at-field__label">Country of Birth</label>
                <select id="at-country" name="country" required class="at-field__input at-field__select">
                  <option value="">Select country…</option>
                </select>
              </div>
              <div class="at-field">
                <label for="at-city" class="at-field__label">City of Birth</label>
                <select
                  id="at-city"
                  name="city"
                  required
                  class="at-field__input at-field__select"
                  disabled
                >
                  <option value="">Select country first…</option>
                </select>
              </div>
            </div>
            <p id="at-error" class="at-error" hidden></p>
            <button type="submit" class="at-submit" id="at-submit">
              ✨ Reveal My Cosmic Journey
            </button>
          </form>

          <div id="at-loading" class="at-loading" hidden>
            <div class="at-loading__orb" aria-hidden="true"></div>
            <p class="at-loading__text">Mapping your celestial chart…</p>
            <p class="at-loading__sub">Our AI astrologer is reading the stars</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ── Steps 2–6: Journey ── -->
  <section id="at-journey" class="at-journey" hidden aria-label="Your cosmic travel journey">
    <Container>
      <!-- Step 2: Profile + domestic/international choice -->
      <div id="at-step-profile" class="at-step">
        <div class="at-profile-card" id="at-profile-card">
          <div class="at-profile-card__sign" id="at-pc-sign"></div>
          <div class="at-profile-card__body">
            <p class="at-profile-card__label">Your Cosmic Sign</p>
            <h2 class="at-profile-card__name" id="at-pc-name"></h2>
            <p class="at-profile-card__meta" id="at-pc-meta"></p>
            <p class="at-profile-card__style" id="at-pc-style"></p>
          </div>
        </div>
        <blockquote class="at-quote" id="at-pc-profile"></blockquote>
        <h3 class="at-step__question">Where does your cosmic journey take you?</h3>
        <div class="at-choice-grid">
          <button class="at-choice-card" id="btn-domestic">
            <span class="at-choice-card__icon">🇮🇳</span>
            <span class="at-choice-card__label">Explore India</span>
            <span class="at-choice-card__sub">Discover your perfect domestic escape</span>
          </button>
          <button class="at-choice-card" id="btn-international">
            <span class="at-choice-card__icon">🌍</span>
            <span class="at-choice-card__label">See the World</span>
            <span class="at-choice-card__sub">Find your cosmic international match</span>
          </button>
        </div>
      </div>

      <!-- Step 3: Beach vs Mountain (domestic only) -->
      <div id="at-step-vibe" class="at-step" hidden>
        <button class="at-back" id="back-to-profile">← Back</button>
        <h3 class="at-step__question">What kind of escape calls to your soul?</h3>
        <div class="at-choice-grid">
          <button class="at-choice-card" id="btn-beach">
            <span class="at-choice-card__icon">🏖️</span>
            <span class="at-choice-card__label">Beach</span>
            <span class="at-choice-card__sub">Sun, sand, and endless horizons</span>
          </button>
          <button class="at-choice-card" id="btn-mountain">
            <span class="at-choice-card__icon">🏔️</span>
            <span class="at-choice-card__label">Mountains</span>
            <span class="at-choice-card__sub">Heights, mist, and inner stillness</span>
          </button>
        </div>
      </div>

      <!-- Step 4: Destination picker -->
      <div id="at-step-destinations" class="at-step" hidden>
        <button class="at-back" id="back-to-vibe">← Back</button>
        <h3 class="at-step__question" id="at-dest-heading">Your Cosmic Destinations</h3>
        <p class="at-step__sub">Choose the one that speaks to your stars</p>
        <div class="at-dest-grid" id="at-dest-grid"></div>
      </div>

      <!-- Step 5: Budget -->
      <div id="at-step-budget" class="at-step" hidden>
        <button class="at-back" id="back-to-destinations">← Back</button>
        <div class="at-selected-badge" id="at-selected-badge"></div>
        <h3 class="at-step__question">What's your travel budget?</h3>
        <p class="at-step__sub">Per person, including flights and stay</p>
        <div class="at-budget-grid">
          <button class="at-budget-card" data-budget="budget">
            <span class="at-budget-card__icon">💚</span>
            <span class="at-budget-card__label">Budget</span>
            <span class="at-budget-card__range">Under ₹25,000</span>
          </button>
          <button class="at-budget-card" data-budget="midrange">
            <span class="at-budget-card__icon">💙</span>
            <span class="at-budget-card__label">Mid-Range</span>
            <span class="at-budget-card__range">₹25,000 – ₹75,000</span>
          </button>
          <button class="at-budget-card" data-budget="premium">
            <span class="at-budget-card__icon">💜</span>
            <span class="at-budget-card__label">Premium</span>
            <span class="at-budget-card__range">₹75,000+</span>
          </button>
        </div>
      </div>

      <!-- Step 6: Booking -->
      <div id="at-step-booking" class="at-step" hidden>
        <button class="at-back" id="back-to-budget">← Back</button>
        <div class="at-booking-header">
          <p class="at-booking-header__eyebrow">✨ Your cosmic trip awaits</p>
          <h3 class="at-booking-header__title" id="at-booking-title"></h3>
          <p class="at-booking-header__sub" id="at-booking-sub"></p>
        </div>
        <div class="at-booking-sections">
          <div class="at-booking-section">
            <h4 class="at-booking-section__title">✈️ Book Flights</h4>
            <div class="at-booking-links" id="at-flight-links"></div>
          </div>
          <div class="at-booking-section">
            <h4 class="at-booking-section__title">🏨 Book Hotels</h4>
            <div class="at-booking-links" id="at-hotel-links"></div>
          </div>
        </div>
        <p class="at-cosmic-msg" id="at-cosmic-msg"></p>
        <button class="at-restart-btn" id="at-restart">✨ Start a new reading</button>
      </div>
    </Container>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  /* ── Hero ── */
  .at-hero {
    position: relative;
    min-height: 100vh;
    background: radial-gradient(ellipse at top, #1a0a3d 0%, #0a0a1a 60%, #000 100%);
    display: flex;
    align-items: center;
    padding: var(--space-20) 0 var(--space-16);
    overflow: hidden;
  }
  .at-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255, 255, 255, 0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 40%, rgba(255, 255, 255, 0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 40% 10%, rgba(255, 255, 255, 0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 65%, rgba(255, 255, 255, 0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 25%, rgba(255, 255, 255, 0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 80% 55%, rgba(255, 255, 255, 0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 80%, rgba(255, 255, 255, 0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 75%, rgba(255, 255, 255, 0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 85%, rgba(255, 255, 255, 0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 90%, rgba(255, 255, 255, 0.8) 0%, transparent 100%),
      radial-gradient(2px 2px at 5% 30%, rgba(255, 255, 255, 0.4) 0%, transparent 100%),
      radial-gradient(2px 2px at 45% 50%, rgba(255, 255, 255, 0.3) 0%, transparent 100%),
      radial-gradient(2px 2px at 75% 70%, rgba(255, 255, 255, 0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 20% 55%, rgba(200, 180, 255, 0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 65% 35%, rgba(180, 200, 255, 0.6) 0%, transparent 100%);
    pointer-events: none;
  }
  .at-hero__inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .at-hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #c4b5fd;
    margin-bottom: var(--space-4);
  }
  .at-hero__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.15;
    color: #fff;
    margin-bottom: var(--space-5);
  }
  .at-hero__subtitle {
    font-size: var(--text-base);
    line-height: 1.7;
    color: #a8a8c8;
    max-width: 480px;
    margin: 0 auto var(--space-10);
  }
  @media (min-width: 768px) {
    .at-hero__title {
      font-size: var(--text-5xl);
    }
    .at-hero__subtitle {
      font-size: var(--text-lg);
    }
  }

  /* ── Form card ── */
  .at-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    backdrop-filter: blur(16px);
    text-align: left;
  }
  .at-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .at-form__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 540px) {
    .at-form__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .at-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .at-field__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: #c4b5fd;
    letter-spacing: 0.02em;
  }
  .at-field__input {
    width: 100%;
    padding: var(--space-3);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    color: #fff;
    font-family: inherit;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
    color-scheme: dark;
  }
  .at-field__input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }
  .at-field__input:focus {
    outline: none;
    border-color: #8b5cf6;
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.25);
  }
  .at-field__select option {
    background: #1a0a3d;
    color: #fff;
  }
  .at-field__hint {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.35);
  }
  .at-error {
    font-size: var(--text-sm);
    color: #f87171;
    text-align: center;
  }
  .at-submit {
    width: 100%;
    padding: var(--space-4);
    background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
    color: #fff;
    font-size: var(--text-base);
    font-weight: 700;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 0.02em;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }
  .at-submit:hover:not(:disabled) {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .at-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* ── Loading ── */
  .at-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-10) 0;
  }
  .at-loading__orb {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #c4b5fd, #7c3aed);
    animation: orb-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.6);
  }
  @keyframes orb-pulse {
    0%,
    100% {
      transform: scale(1);
      box-shadow: 0 0 30px rgba(139, 92, 246, 0.6);
    }
    50% {
      transform: scale(1.15);
      box-shadow: 0 0 50px rgba(139, 92, 246, 0.9);
    }
  }
  .at-loading__text {
    font-size: var(--text-lg);
    font-weight: 600;
    color: #e2e2f0;
  }
  .at-loading__sub {
    font-size: var(--text-sm);
    color: #8888aa;
  }

  /* ── Journey area ── */
  .at-journey {
    padding: var(--space-12) 0 var(--space-8);
    background: var(--color-neutral-0);
    min-height: 60vh;
  }

  /* ── Steps ── */
  .at-step {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-6) 0 var(--space-10);
  }
  .at-step__question {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    text-align: center;
    margin-bottom: var(--space-3);
  }
  .at-step__sub {
    font-size: var(--text-base);
    color: var(--color-neutral-500);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  /* ── Profile card ── */
  .at-profile-card {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    background: linear-gradient(135deg, #1a0a3d 0%, #0f0a2a 100%);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    margin-bottom: var(--space-8);
    color: #fff;
    flex-wrap: wrap;
  }
  .at-profile-card__sign {
    font-size: 4rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .at-profile-card__body {
    flex: 1;
    min-width: 200px;
  }
  .at-profile-card__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a78bfa;
    margin-bottom: var(--space-1);
  }
  .at-profile-card__name {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: #fff;
    margin-bottom: var(--space-1);
  }
  .at-profile-card__meta {
    font-size: var(--text-sm);
    color: #c4b5fd;
    margin-bottom: var(--space-2);
  }
  .at-profile-card__style {
    font-size: var(--text-base);
    font-weight: 700;
    color: #fbbf24;
  }

  /* ── Quote ── */
  .at-quote {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-neutral-600);
    font-style: italic;
    text-align: center;
    border-left: 3px solid #7c3aed;
    padding-left: var(--space-5);
    margin: 0 auto var(--space-10);
    max-width: 600px;
  }

  /* ── Choice grid ── */
  .at-choice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  @media (max-width: 540px) {
    .at-choice-grid {
      grid-template-columns: 1fr;
    }
  }
  .at-choice-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-6);
    background: #fff;
    border: 2px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition:
      border-color 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
    font-family: inherit;
    text-align: center;
  }
  .at-choice-card:hover {
    border-color: #7c3aed;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.12);
  }
  .at-choice-card__icon {
    font-size: 3rem;
  }
  .at-choice-card__label {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-neutral-900);
  }
  .at-choice-card__sub {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    line-height: 1.4;
  }

  /* ── Back button ── */
  .at-back {
    background: none;
    border: none;
    font-size: var(--text-sm);
    color: var(--color-neutral-400);
    cursor: pointer;
    font-family: inherit;
    padding: var(--space-2) 0;
    margin-bottom: var(--space-6);
    display: block;
    transition: color 0.15s;
  }
  .at-back:hover {
    color: var(--color-neutral-700);
  }

  /* ── Destination grid ── */
  .at-dest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-4);
  }
  .at-dest-pick-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-5);
    background: #fff;
    border: 2px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition:
      border-color 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
    font-family: inherit;
    text-align: center;
    width: 100%;
  }
  .at-dest-pick-card:hover {
    border-color: #7c3aed;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.12);
  }
  .at-dest-pick-card__emoji {
    font-size: 2.5rem;
  }
  .at-dest-pick-card__name {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-neutral-900);
  }
  .at-dest-pick-card__loc {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-primary-600);
  }
  .at-dest-pick-card__tagline {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-neutral-700);
    font-style: italic;
  }
  .at-dest-pick-card__why {
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
    line-height: 1.5;
  }

  /* ── Selected badge ── */
  .at-selected-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: #f5f3ff;
    border: 1px solid #ddd6fe;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: #7c3aed;
    margin-bottom: var(--space-8);
    font-weight: 500;
  }

  /* ── Budget grid ── */
  .at-budget-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .at-budget-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-6);
    background: #fff;
    border: 2px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition:
      border-color 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
    font-family: inherit;
    text-align: center;
    width: 100%;
  }
  .at-budget-card:hover {
    border-color: #7c3aed;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.12);
  }
  .at-budget-card__icon {
    font-size: 2rem;
  }
  .at-budget-card__label {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-neutral-900);
  }
  .at-budget-card__range {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
  }

  /* ── Booking ── */
  .at-booking-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }
  .at-booking-header__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #7c3aed;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }
  .at-booking-header__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-2);
  }
  .at-booking-header__sub {
    font-size: var(--text-base);
    color: var(--color-neutral-500);
  }
  .at-booking-sections {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
  }
  @media (max-width: 640px) {
    .at-booking-sections {
      grid-template-columns: 1fr;
    }
  }
  .at-booking-section__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-neutral-800);
    margin-bottom: var(--space-4);
  }
  .at-booking-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .at-booking-link {
    display: block;
    padding: var(--space-4);
    background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
    color: #fff;
    font-weight: 700;
    border-radius: var(--radius-md);
    text-decoration: none;
    text-align: center;
    transition:
      opacity 0.2s,
      transform 0.2s;
    font-size: var(--text-sm);
  }
  .at-booking-link:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .at-cosmic-msg {
    text-align: center;
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-8);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .at-restart-btn {
    display: block;
    margin: 0 auto;
    padding: var(--space-3) var(--space-8);
    background: none;
    border: 2px solid #7c3aed;
    color: #7c3aed;
    font-size: var(--text-base);
    font-weight: 700;
    border-radius: var(--radius-full);
    cursor: pointer;
    font-family: inherit;
    transition:
      background 0.2s,
      color 0.2s;
  }
  .at-restart-btn:hover {
    background: #7c3aed;
    color: #fff;
  }
</style>

<script>
  // ── Cities data ──
  const CITIES: Record<string, string[]> = {
    Australia: ['Adelaide', 'Brisbane', 'Melbourne', 'Perth', 'Sydney'],
    Canada: ['Calgary', 'Montreal', 'Ottawa', 'Toronto', 'Vancouver'],
    France: ['Lyon', 'Marseille', 'Nice', 'Paris'],
    Germany: ['Berlin', 'Frankfurt', 'Hamburg', 'Munich'],
    India: [
      'Ahmedabad',
      'Bangalore',
      'Bhopal',
      'Chandigarh',
      'Chennai',
      'Delhi',
      'Guwahati',
      'Hyderabad',
      'Indore',
      'Jaipur',
      'Kochi',
      'Kolkata',
      'Lucknow',
      'Mumbai',
      'Nagpur',
      'Patna',
      'Pune',
      'Surat',
      'Vadodara',
      'Varanasi',
      'Visakhapatnam',
    ],
    Indonesia: ['Bali', 'Jakarta', 'Surabaya'],
    Italy: ['Florence', 'Milan', 'Rome', 'Venice'],
    Japan: ['Kyoto', 'Osaka', 'Tokyo'],
    Malaysia: ['Johor Bahru', 'Kuala Lumpur', 'Penang'],
    Nepal: ['Kathmandu', 'Pokhara'],
    Netherlands: ['Amsterdam', 'Rotterdam'],
    'New Zealand': ['Auckland', 'Christchurch', 'Wellington'],
    Portugal: ['Lisbon', 'Porto'],
    Singapore: ['Singapore'],
    'South Africa': ['Cape Town', 'Durban', 'Johannesburg'],
    Spain: ['Barcelona', 'Madrid', 'Seville'],
    'Sri Lanka': ['Colombo', 'Kandy'],
    Thailand: ['Bangkok', 'Chiang Mai', 'Phuket'],
    Turkey: ['Ankara', 'Istanbul'],
    UAE: ['Abu Dhabi', 'Dubai', 'Sharjah'],
    UK: ['Birmingham', 'Edinburgh', 'Glasgow', 'Leeds', 'London', 'Manchester'],
    USA: [
      'Chicago',
      'Dallas',
      'Houston',
      'Las Vegas',
      'Los Angeles',
      'Miami',
      'New York',
      'San Francisco',
      'Seattle',
    ],
    Vietnam: ['Da Nang', 'Hanoi', 'Ho Chi Minh City'],
  }

  // ── State ──
  type DestItem = { name: string; state?: string; emoji: string; tagline: string; whyItFits: string }
  type ReadingData = {
    sign: string; symbol: string; element: string; risingSign: string
    cosmicProfile: string; travelStyle: string; cosmicMessage: string
    domesticBeach: DestItem[]; domesticMountain: DestItem[]
    international: DestItem[]
  }

  let readingData: ReadingData | null = null
  let journeyType = ''
  let selectedDest: DestItem | null = null

  // ── DOM refs ──
  const countryEl = document.getElementById('at-country') as HTMLSelectElement | null
  const cityEl = document.getElementById('at-city') as HTMLSelectElement | null
  const form = document.getElementById('at-form') as HTMLFormElement | null
  const loadingEl = document.getElementById('at-loading') as HTMLElement | null
  const errorEl = document.getElementById('at-error') as HTMLElement | null
  const submitBtn = document.getElementById('at-submit') as HTMLButtonElement | null
  const formCard = document.getElementById('at-form-card') as HTMLElement | null
  const stepForm = document.getElementById('at-step-form') as HTMLElement | null
  const journey = document.getElementById('at-journey') as HTMLElement | null

  // ── Populate countries ──
  if (countryEl) {
    Object.keys(CITIES)
      .sort()
      .forEach((c) => {
        const opt = document.createElement('option')
        opt.value = c
        opt.textContent = c
        countryEl.appendChild(opt)
      })
  }

  countryEl?.addEventListener('change', () => {
    if (!cityEl || !countryEl) return
    const cities = CITIES[countryEl.value] ?? []
    cityEl.innerHTML = ''
    if (!cities.length) {
      cityEl.innerHTML = '<option value="">Select country first…</option>'
      cityEl.disabled = true
      return
    }
    cityEl.disabled = false
    const ph = document.createElement('option')
    ph.value = ''
    ph.textContent = 'Select city…'
    cityEl.appendChild(ph)
    cities.forEach((city) => {
      const opt = document.createElement('option')
      opt.value = city
      opt.textContent = city
      cityEl.appendChild(opt)
    })
  })

  // ── Helpers ──
  function setText(id: string, val: string) {
    const el = document.getElementById(id)
    if (el) el.textContent = val
  }

  function showStep(id: string) {
    ;[
      'at-step-profile',
      'at-step-vibe',
      'at-step-destinations',
      'at-step-budget',
      'at-step-booking',
    ].forEach((s) => {
      const el = document.getElementById(s)
      if (el) el.hidden = s !== id
    })
    journey?.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  function showError(msg: string) {
    if (errorEl) { errorEl.textContent = msg; errorEl.hidden = false }
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '✨ Reveal My Cosmic Journey' }
    if (loadingEl) loadingEl.hidden = true
    if (form) form.hidden = false
  }

  // ── Form submit ──
  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (errorEl) errorEl.hidden = true

    const dob = (document.getElementById('dob') as HTMLInputElement).value
    const tob = (document.getElementById('tob') as HTMLInputElement).value
    const country = countryEl?.value ?? ''
    const city = cityEl?.value ?? ''

    if (!dob || !tob || !country || !city) {
      showError('Please fill in all fields.')
      return
    }

    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Reading your chart…' }
    if (form) form.hidden = true
    if (loadingEl) loadingEl.hidden = false

    try {
      const res = await fetch('/api/astro-reading', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dob, tob, pob: `${city}, ${country}` }),
      })
      const data = await res.json()
      if (!res.ok || data.error) { showError(data.error || 'Something went wrong.'); return }

      readingData = data
      if (loadingEl) loadingEl.hidden = true
      if (formCard) formCard.hidden = true

      setText('at-pc-sign', data.symbol ?? '')
      setText('at-pc-name', data.sign ?? '')
      setText('at-pc-meta', `${data.element} Sign · Rising: ${data.risingSign}`)
      setText('at-pc-style', `🌟 ${data.travelStyle}`)
      setText('at-pc-profile', data.cosmicProfile ?? '')

      if (stepForm) stepForm.hidden = true
      if (journey) journey.hidden = false
      showStep('at-step-profile')
    } catch {
      showError('Network error. Please check your connection and try again.')
    }
  })

  // ── Step 2: Journey type ──
  document.getElementById('btn-domestic')?.addEventListener('click', () => {
    journeyType = 'domestic'
    showStep('at-step-vibe')
  })
  document.getElementById('btn-international')?.addEventListener('click', () => {
    journeyType = 'international'
    renderDestinations(readingData?.international ?? [], 'Country')
    showStep('at-step-destinations')
  })

  // ── Step 3: Vibe ──
  document.getElementById('btn-beach')?.addEventListener('click', () => {
    renderDestinations(readingData?.domesticBeach ?? [], 'State')
    showStep('at-step-destinations')
  })
  document.getElementById('btn-mountain')?.addEventListener('click', () => {
    renderDestinations(readingData?.domesticMountain ?? [], 'State')
    showStep('at-step-destinations')
  })

  // ── Step 4: Render destinations ──
  function renderDestinations(dests: DestItem[], locLabel: string) {
    const heading = journeyType === 'international'
      ? 'Your International Cosmic Matches'
      : 'Your Destined Escapes'
    setText('at-dest-heading', heading)

    const grid = document.getElementById('at-dest-grid')
    if (!grid) return
    grid.innerHTML = ''
    dests.forEach((dest) => {
      const btn = document.createElement('button')
      btn.className = 'at-dest-pick-card'
      btn.innerHTML = `
        <span class="at-dest-pick-card__emoji">${dest.emoji}</span>
        <span class="at-dest-pick-card__name">${dest.name}</span>
        <span class="at-dest-pick-card__loc">${dest.state ?? ''}</span>
        <span class="at-dest-pick-card__tagline">${dest.tagline}</span>
        <span class="at-dest-pick-card__why">${dest.whyItFits}</span>
      `
      btn.addEventListener('click', () => selectDestination(dest))
      grid.appendChild(btn)
    })
  }

  // ── Step 5: Select destination → budget ──
  function selectDestination(dest: DestItem) {
    selectedDest = dest
    const badge = document.getElementById('at-selected-badge')
    if (badge) badge.innerHTML = `<span>${dest.emoji}</span> <strong>${dest.name}</strong>${dest.state ? ', ' + dest.state : ''}`
    showStep('at-step-budget')
  }

  // ── Step 6: Budget → booking ──
  document.querySelectorAll('.at-budget-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      const budget = (btn as HTMLElement).dataset.budget ?? ''
      showBooking(budget)
    })
  })

  function showBooking(budget: string) {
    if (!selectedDest) return
    const isIntl = journeyType === 'international'
    const dest = selectedDest.name
    const loc = isIntl ? dest : `${dest}${selectedDest.state ? ', ' + selectedDest.state : ''}`
    const budgetLabel = { budget: 'Budget friendly', midrange: 'Mid-range comfort', premium: 'Premium experience' }[budget] ?? ''

    setText('at-booking-title', `${selectedDest.emoji} ${loc}`)
    setText('at-booking-sub', `${budgetLabel} · ${isIntl ? 'International' : 'Domestic'} trip`)
    setText('at-cosmic-msg', readingData?.cosmicMessage ?? '')

    const enc = encodeURIComponent(dest)

    const flights = isIntl
      ? [
          { label: '✈️ Skyscanner', url: `https://www.skyscanner.co.in/transport/flights/del/${enc.toLowerCase()}/` },
          { label: '✈️ MakeMyTrip International', url: 'https://www.makemytrip.com/flights/international/' },
          { label: '✈️ Cleartrip International', url: 'https://www.cleartrip.com/flights/international/' },
        ]
      : [
          { label: '✈️ MakeMyTrip Domestic', url: 'https://www.makemytrip.com/flights/domestic/' },
          { label: '✈️ Cleartrip', url: 'https://www.cleartrip.com/flights' },
          { label: '✈️ IndiGo', url: 'https://www.goindigo.in' },
        ]

    const hotels = [
      { label: '🏨 MakeMyTrip Hotels', url: `https://www.makemytrip.com/hotels/${enc.toLowerCase()}-hotels.html` },
      { label: '🏨 Booking.com', url: `https://www.booking.com/searchresults.html?ss=${enc}` },
      { label: '🏨 Agoda', url: `https://www.agoda.com/search?city=${enc}` },
    ]

    const flightContainer = document.getElementById('at-flight-links')
    if (flightContainer) {
      flightContainer.innerHTML = flights
        .map((l) => `<a href="${l.url}" target="_blank" rel="noopener noreferrer" class="at-booking-link">${l.label}</a>`)
        .join('')
    }
    const hotelContainer = document.getElementById('at-hotel-links')
    if (hotelContainer) {
      hotelContainer.innerHTML = hotels
        .map((l) => `<a href="${l.url}" target="_blank" rel="noopener noreferrer" class="at-booking-link">${l.label}</a>`)
        .join('')
    }

    showStep('at-step-booking')
  }

  // ── Back navigation ──
  document.getElementById('back-to-profile')?.addEventListener('click', () => showStep('at-step-profile'))
  document.getElementById('back-to-vibe')?.addEventListener('click', () => {
    showStep(journeyType === 'domestic' ? 'at-step-vibe' : 'at-step-profile')
  })
  document.getElementById('back-to-destinations')?.addEventListener('click', () => showStep('at-step-destinations'))
  document.getElementById('back-to-budget')?.addEventListener('click', () => showStep('at-step-budget'))

  // ── Restart ──
  document.getElementById('at-restart')?.addEventListener('click', () => {
    readingData = null
    journeyType = ''
    selectedDest = null
    if (journey) journey.hidden = true
    if (stepForm) stepForm.hidden = false
    if (formCard) formCard.hidden = false
    if (form) form.hidden = false
    if (loadingEl) loadingEl.hidden = true
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '✨ Reveal My Cosmic Journey' }
    window.scrollTo({ top: 0, behavior: 'smooth' })
  })
</script>
