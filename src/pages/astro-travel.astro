</style>

<script>
  // ── Carousel ──
  const slides = document.querySelectorAll<HTMLElement>('.carousel__slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.carousel__dot');
  let current = 0;
  let autoTimer: ReturnType<typeof setInterval>;

  function goTo(index: number): void {
    slides[current].setAttribute('aria-hidden', 'true');
    dots[current].setAttribute('aria-selected', 'false');
    current = (index + slides.length) % slides.length;
    slides[current].setAttribute('aria-hidden', 'false');
    dots[current].setAttribute('aria-selected', 'true');
  }

  function startAuto(): void {
    autoTimer = setInterval(() => goTo(current + 1), 5000);
  }

  function resetAuto(): void {
    clearInterval(autoTimer);
    startAuto();
  }

  document.getElementById('carousel-prev')?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
  document.getElementById('carousel-next')?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
  dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetAuto(); }));

  startAuto();

  // ── Zodiac calculator ──
  const zodiacData = [
    { sign: 'Capricorn', symbol: '♑', destination: 'Machu Picchu, Peru', tagline: 'Summit the clouds — a reward worthy of your ambition.', emoji: '🏛️' },
    { sign: 'Aquarius',  symbol: '♒', destination: 'New Zealand',         tagline: 'Untouched landscapes that rewrite what travel can be.', emoji: '🌿' },
    { sign: 'Pisces',    symbol: '♓', destination: 'Bali, Indonesia',      tagline: 'Temple rituals, rice terraces, and spiritual surrender.', emoji: '🌺' },
    { sign: 'Aries',     symbol: '♈', destination: 'Iceland',              tagline: 'Chase volcanoes, waterfalls, and the Northern Lights.', emoji: '🌋' },
    { sign: 'Taurus',    symbol: '♉', destination: 'Tuscany, Italy',       tagline: 'Rolling vineyards, fine cuisine, and timeless beauty.', emoji: '🍷' },
    { sign: 'Gemini',    symbol: '♊', destination: 'Tokyo, Japan',         tagline: 'Ancient temples and neon streets — two worlds in one city.', emoji: '🏙️' },
    { sign: 'Cancer',    symbol: '♋', destination: 'Maldives',             tagline: 'Overwater sanctuaries where the ocean meets the sky.', emoji: '🌊' },
    { sign: 'Leo',       symbol: '♌', destination: 'Santorini, Greece',    tagline: 'Golden sunsets on clifftop villages made for royalty.', emoji: '☀️' },
    { sign: 'Virgo',     symbol: '♍', destination: 'Kyoto, Japan',         tagline: 'Zen gardens, bamboo groves, and meticulous perfection.', emoji: '🎋' },
    { sign: 'Libra',     symbol: '♎', destination: 'Paris, France',        tagline: 'Art, romance, and the most beautiful city on Earth.', emoji: '🗼' },
    { sign: 'Scorpio',   symbol: '♏', destination: 'Marrakech, Morocco',   tagline: 'Labyrinthine souks, mystic riads, and desert mystery.', emoji: '🕌' },
    { sign: 'Sagittarius', symbol: '♐', destination: 'Patagonia, Argentina', tagline: 'Edge-of-the-world landscapes for the ultimate explorer.', emoji: '🏔️' },
  ];

  function getZodiacSign(month: number, day: number): typeof zodiacData[0] {
    if ((month === 12 && day >= 22) || (month === 1 && day <= 19)) return zodiacData[0];
    if ((month === 1 && day >= 20) || (month === 2 && day <= 18)) return zodiacData[1];
    if ((month === 2 && day >= 19) || (month === 3 && day <= 20)) return zodiacData[2];
    if ((month === 3 && day >= 21) || (month === 4 && day <= 19)) return zodiacData[3];
    if ((month === 4 && day >= 20) || (month === 5 && day <= 20)) return zodiacData[4];
    if ((month === 5 && day >= 21) || (month === 6 && day <= 20)) return zodiacData[5];
    if ((month === 6 && day >= 21) || (month === 7 && day <= 22)) return zodiacData[6];
    if ((month === 7 && day >= 23) || (month === 8 && day <= 22)) return zodiacData[7];
    if ((month === 8 && day >= 23) || (month === 9 && day <= 22)) return zodiacData[8];
    if ((month === 9 && day >= 23) || (month === 10 && day <= 22)) return zodiacData[9];
    if ((month === 10 && day >= 23) || (month === 11 && day <= 21)) return zodiacData[10];
    return zodiacData[11];
  }

  const astroForm = document.getElementById('astro-form') as HTMLFormElement | null;
  const astroResult = document.getElementById('astro-result') as HTMLElement | null;
  const errorEl = document.getElementById('astro-form-error') as HTMLElement | null;

  astroForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (errorEl) errorEl.hidden = true;

    const dob = (astroForm.querySelector('#dob') as HTMLInputElement).value;
    const tob = (astroForm.querySelector('#tob') as HTMLInputElement).value;
    const pob = (astroForm.querySelector('#pob') as HTMLInputElement).value.trim();
    const email = (astroForm.querySelector('#astro-email') as HTMLInputElement).value.trim();

    if (!dob || !tob || !pob || !email) {
      if (errorEl) { errorEl.textContent = 'Please fill in all fields.'; errorEl.hidden = false; }
      return;
    }

    const date = new Date(dob);
    const month = date.getMonth() + 1;
    const day = date.getDate();
    const zodiac = getZodiacSign(month, day);

    const signEl = document.getElementById('astro-result-sign');
    const destEl = document.getElementById('astro-result-destination');
    const tagEl = document.getElementById('astro-result-tagline');
    if (signEl) signEl.textContent = `${zodiac.emoji} ${zodiac.symbol} ${zodiac.sign}`;
    if (destEl) destEl.textContent = zodiac.destination;
    if (tagEl) tagEl.textContent = zodiac.tagline;

    astroForm.hidden = true;
    if (astroResult) astroResult.hidden = false;

    // Send lead email in background
    fetch('https://formsubmit.co/ajax/harshmathur15@gmail.com', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({
        _subject: 'New Astro Travel Request — Travel Baby',
        _captcha: 'false',
        dob, tob, pob, email,
        zodiac_sign: zodiac.sign,
        recommended_destination: zodiac.destination,
      }),
    }).catch(() => {});
  });
</script>
