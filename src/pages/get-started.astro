---
/* Product-specific — edit this page directly, not via config */
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';
---

<BaseLayout title="Get Started" description="Get up and running in minutes. Clone, customize, and launch your website.">
  <section class="get-started" aria-labelledby="get-started-heading">
    <Container size="md">
      <SectionHeading
        title="Get Started in Minutes"
        subtitle="Clone the boilerplate, customize your brand, and launch. Everything is already set up."
        as="h1"
      />

      <div class="steps">
        <div class="step">
          <span class="step__number" aria-hidden="true">1</span>
          <h2 class="step__title">Clone the Repository</h2>
          <p class="step__text">Clone this repo into your new project directory and install dependencies.</p>
          <pre class="step__code"><code>git clone &lt;repo-url&gt; my-website
cd my-website
npm install</code></pre>
        </div>

        <div class="step">
          <span class="step__number" aria-hidden="true">2</span>
          <h2 class="step__title">Customize Your Brand</h2>
          <p class="step__text">Edit the design tokens in <code>src/styles/global.css</code> to match your brand colors, fonts, and spacing.</p>
        </div>

        <div class="step">
          <span class="step__number" aria-hidden="true">3</span>
          <h2 class="step__title">Start Building</h2>
          <p class="step__text">Run the dev server and start customizing pages, components, and content.</p>
          <pre class="step__code"><code>npm run dev</code></pre>
        </div>
      </div>

      <div class="get-started__cta">
        <Button variant="primary" size="lg" href="/">
          Back to Home
        </Button>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .get-started {
    padding: var(--space-16) 0 var(--space-20);
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    margin-top: var(--space-4);
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .step__number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--color-primary-100);
    color: var(--color-primary-700);
    font-weight: 700;
    font-size: var(--text-lg);
  }

  .step__title {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-neutral-900);
  }

  .step__text {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-neutral-600);
  }

  .step__text code {
    background: var(--color-neutral-100);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
  }

  .step__code {
    background: var(--color-neutral-900);
    color: var(--color-neutral-100);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    overflow-x: auto;
  }

  .step__code code {
    font-family: var(--font-mono);
  }

  .get-started__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-12);
  }
</style>
