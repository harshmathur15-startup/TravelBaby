---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import { ABOUT_PAGE } from '@config';

const { hero, mission, values, team } = ABOUT_PAGE;
---

<BaseLayout title="About" description={hero.subtitle}>
  <!-- Hero -->
  <section class="about-hero" aria-labelledby="about-hero-heading">
    <Container>
      <div class="about-hero__inner">
        <SectionHeading
          title={hero.title}
          subtitle={hero.subtitle}
          as="h1"
          id="about-hero-heading"
        />
      </div>
    </Container>
  </section>

  <!-- Mission -->
  <section class="about-mission" aria-labelledby="mission-heading">
    <Container>
      <div class="about-mission__grid">
        <div class="about-mission__content">
          <h2 id="mission-heading" class="about-mission__title">{mission.title}</h2>
          {mission.paragraphs.map((p) => (
            <p class="about-mission__text">{p}</p>
          ))}
        </div>
        <div class="about-mission__visual">
          <img
            src="/images/about-mission-1.jpg"
            alt="Family enjoying a vacation together"
            loading="lazy"
          />
        </div>
      </div>
    </Container>
  </section>

  <!-- Values -->
  <section class="about-values" aria-labelledby="values-heading">
    <Container>
      <SectionHeading
        title={values.title}
        subtitle={values.subtitle}
        id="values-heading"
      />
      <div class="about-values__grid">
        {values.items.map((value) => (
          <Card variant="outlined" padding="lg">
            <div class="about-values__icon" aria-hidden="true">
              <Fragment set:html={value.icon} />
            </div>
            <h3 class="about-values__card-title">{value.title}</h3>
            <p class="about-values__card-text">{value.description}</p>
          </Card>
        ))}
      </div>
    </Container>
  </section>

  <!-- Team -->
  <section class="about-team" aria-labelledby="team-heading">
    <Container>
      <SectionHeading
        title={team.title}
        subtitle={team.subtitle}
        id="team-heading"
      />
      <div class="about-team__grid">
        {team.members.map((member) => (
          <div class="about-team__member">
            <div class="about-team__avatar" aria-hidden="true">
              <span>{member.name.split(' ').map((n) => n[0]).join('')}</span>
            </div>
            <h3 class="about-team__name">{member.name}</h3>
            <p class="about-team__role">{member.role}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-neutral-0) 100%);
  }
  .about-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  /* Mission */
  .about-mission {
    padding: var(--space-12) 0;
  }
  .about-mission__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
  }
  .about-mission__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-4);
  }
  .about-mission__text {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-4);
  }
  .about-mission__text:last-child {
    margin-bottom: 0;
  }
  .about-mission__visual {
    display: flex;
    justify-content: center;
  }
  .about-mission__visual img {
    width: 100%;
    max-width: 480px;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    box-shadow: var(--shadow-md);
  }
  .about-mission__placeholder {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4 / 3;
    background: var(--color-neutral-100);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-neutral-400);
    font-size: var(--text-lg);
    font-weight: 500;
  }
  @media (min-width: 768px) {
    .about-mission__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Values */
  .about-values {
    padding: var(--space-12) 0;
    background: var(--color-neutral-50);
  }
  .about-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-8);
  }
  .about-values__icon {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
    color: var(--color-primary-600);
  }
  .about-values__card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-2);
  }
  .about-values__card-text {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-neutral-600);
  }
  @media (min-width: 768px) {
    .about-values__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .about-values__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Team */
  .about-team {
    padding: var(--space-12) 0;
  }
  .about-team__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    margin-top: var(--space-8);
  }
  .about-team__member {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .about-team__avatar {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background: var(--color-primary-100);
    color: var(--color-primary-700);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }
  .about-team__name {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-neutral-900);
  }
  .about-team__role {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    margin-top: var(--space-1);
  }
  @media (min-width: 768px) {
    .about-team__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .about-hero {
      padding: var(--space-20) 0 var(--space-16);
    }
  }
</style>
