---
/**
 * Content Preview Page
 *
 * Loads Sanity draft content client-side using the Sanity Presentation API.
 * Requires SANITY_PROJECT_ID and a valid preview token passed as ?token= query param.
 *
 * Usage:
 *   /preview?type=blogPost&slug=my-post&token=sk...
 *
 * This page runs entirely client-side — no output: 'hybrid' needed.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';

const projectId = import.meta.env.SANITY_PROJECT_ID ?? '';
const dataset = import.meta.env.SANITY_DATASET ?? 'production';
---

<BaseLayout title="Content Preview" description="Preview draft CMS content.">
  <section class="preview-page">
    <Container size="md">
      <div id="preview-status" class="preview-status">
        <p class="preview-status__label">Draft Preview Mode</p>
        <p class="preview-status__hint">Loading draft content...</p>
      </div>
      <div id="preview-content" class="preview-content"></div>
      <div id="preview-error" class="preview-error" hidden>
        <p>Could not load preview. Check that:</p>
        <ul>
          <li>SANITY_PROJECT_ID is configured</li>
          <li>A valid token is provided (?token=...)</li>
          <li>The document type and slug are correct</li>
        </ul>
        <a href="/">Back to home</a>
      </div>
    </Container>
  </section>
</BaseLayout>

<script is:inline define:vars={{ projectId, dataset }}>
  async function loadPreview() {
    const params = new URLSearchParams(window.location.search);
    const type = params.get('type') || 'blogPost';
    const slug = params.get('slug');
    const token = params.get('token');

    const statusEl = document.getElementById('preview-status');
    const contentEl = document.getElementById('preview-content');
    const errorEl = document.getElementById('preview-error');

    if (!projectId || !token || !slug) {
      statusEl.hidden = true;
      errorEl.hidden = false;
      return;
    }

    try {
      const query = encodeURIComponent(
        `*[_type == "${type}" && slug.current == "${slug}"][0]{ title, slug, excerpt, body[]{ ..., _type == "image" => { ..., asset-> } }, publishedAt, categories, author->{ name } }`
      );
      const url = `https://${projectId}.api.sanity.io/v2024-01-01/data/query/${dataset}?query=${query}`;
      const res = await fetch(url, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const data = await res.json();
      const doc = data.result;

      if (!doc) {
        statusEl.querySelector('.preview-status__hint').textContent = 'Document not found.';
        return;
      }

      statusEl.querySelector('.preview-status__hint').textContent = `Previewing: ${doc.title}`;

      let html = `<h1 style="font-size:2rem;font-weight:800;margin-bottom:1rem;">${doc.title}</h1>`;
      if (doc.excerpt) html += `<p style="color:#666;margin-bottom:2rem;">${doc.excerpt}</p>`;
      if (doc.body) {
        for (const block of doc.body) {
          if (block._type === 'block') {
            const text = (block.children || []).map(c => c.text).join('');
            if (block.style === 'h2') html += `<h2 style="font-size:1.5rem;font-weight:700;margin:1.5rem 0 0.75rem;">${text}</h2>`;
            else if (block.style === 'h3') html += `<h3 style="font-size:1.25rem;font-weight:600;margin:1rem 0 0.5rem;">${text}</h3>`;
            else html += `<p style="line-height:1.8;margin-bottom:1rem;">${text}</p>`;
          }
        }
      }
      contentEl.innerHTML = html;
    } catch (err) {
      statusEl.hidden = true;
      errorEl.hidden = false;
    }
  }
  loadPreview();
</script>

<style>
  .preview-page {
    padding: var(--space-16) 0;
    min-height: 60vh;
  }
  .preview-status {
    background: var(--color-accent-50);
    border: 1px solid var(--color-accent-200);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-6);
    margin-bottom: var(--space-8);
  }
  .preview-status__label {
    font-weight: 600;
    color: var(--color-accent-700);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .preview-status__hint {
    color: var(--color-accent-600);
    font-size: var(--text-sm);
    margin-top: var(--space-1);
  }
  .preview-content {
    color: var(--color-neutral-700);
  }
  .preview-error {
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    color: var(--color-neutral-600);
    font-size: var(--text-sm);
  }
  .preview-error ul {
    margin: var(--space-3) 0;
    padding-left: var(--space-6);
  }
  .preview-error a {
    color: var(--color-primary-600);
    font-weight: 500;
  }
</style>
