{
  "description": "Files protected by drift detection and edit-time protection. Single source of truth for both drift-check.cjs and file-protection.js. Add project-specific entries after cloning.",
  "files": [
    { "key": "CLAUDE.md", "path": "./CLAUDE.md", "protection": "warn" },
    { "key": "settings", "path": "./.claude/settings.json", "protection": "block" },
    { "key": "rules:general", "path": "./.claude/rules/general.md", "protection": "warn" },
    { "key": "rules:security", "path": "./.claude/rules/security.md", "protection": "warn" },
    { "key": "rules:frontend", "path": "./.claude/rules/frontend.md", "protection": "warn" },
    { "key": "rules:performance", "path": "./.claude/rules/performance.md", "protection": "warn" },
    { "key": "rules:testing", "path": "./.claude/rules/testing.md", "protection": "warn" },
    { "key": "rules:agents", "path": "./.claude/rules/agents.md", "protection": "warn" },
    { "key": "rules:backend", "path": "./.claude/rules/backend.md", "protection": "warn" },
    { "key": "rules:database", "path": "./.claude/rules/database.md", "protection": "warn" },
    { "key": "package.json", "path": "./package.json", "protection": "block" },
    { "key": "family:registry", "path": "./agents/family/registry.md", "protection": "warn" }
  ],
  "blocked_patterns": [
    "\\.env$",
    "\\.env\\.local$",
    "node_modules/",
    "package-lock\\.json$",
    "prisma/migrations/"
  ]
}
