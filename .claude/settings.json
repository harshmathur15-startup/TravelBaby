{
  "permissions": {
    "additionalDirectories": [],
    "allow": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let b='';process.stdin.on('data',c=>b+=c);process.stdin.on('end',()=>{const d=JSON.parse(b);const cmd=(d.tool_input&&d.tool_input.command||'').toLowerCase();const patterns=[/rm\\s+(-[a-z]*f[a-z]*\\s+|.*--force)/,/drop\\s+table/,/git\\s+push\\s+.*(-f|--force)/,/format\\s+c/,/find\\s+.*-delete/,/truncate\\s/,/mkfs\\./,/git\\s+add\\s+.*\\.env(?!\\.)/,/git\\s+commit.*\\.env(?!\\.)/,/while\\s+(true|1|:)/,/\\brm\\s+-i/,/\\bcp\\s+-i/,/\\bmv\\s+-i/,/gh\\s+run\\s+watch/,/find\\s+\\/\\s/];const hit=patterns.find(p=>p.test(cmd));if(hit){process.stderr.write('BLOCKED: Dangerous command detected\\n');process.exit(2);}process.exit(0);});\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/file-protection.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/handoff-generator.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let b='';process.stdin.on('data',c=>b+=c);process.stdin.on('end',()=>{const d=JSON.parse(b);const f=d.tool_input&&d.tool_input.file_path||'';if(f.match(/\\.(ts|tsx|js|jsx)$/)){const {execSync}=require('child_process');try{execSync('npx prettier --write \\\"'+f+'\\\" 2>/dev/null',{stdio:'ignore'});}catch(e){}}});\""
          },
          {
            "type": "command",
            "command": "node scripts/quality-gate.js"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-tracker.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-stop.js"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/mcp-sequential-thinking"
      ]
    }
  }
}
