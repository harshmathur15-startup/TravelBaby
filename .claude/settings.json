{
  "permissions": {
    "additionalDirectories": [],
    "allow": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let b='';process.stdin.on('data',c=>b+=c);process.stdin.on('end',()=>{const d=JSON.parse(b);const cmd=(d.tool_input&&d.tool_input.command||'').toLowerCase();const patterns=[/rm\\s+(-[a-z]*f[a-z]*\\s+|.*--force)/,/drop\\s+table/,/git\\s+push\\s+.*(-f|--force)/,/format\\s+c/,/find\\s+.*-delete/,/truncate\\s/,/mkfs\\./];const hit=patterns.find(p=>p.test(cmd));if(hit){process.stderr.write('BLOCKED: Dangerous command detected\\n');process.exit(2);}process.exit(0);});\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let b='';process.stdin.on('data',c=>b+=c);process.stdin.on('end',()=>{const d=JSON.parse(b);const f=d.tool_input&&d.tool_input.file_path||'';if(f.match(/\\.(ts|tsx|js|jsx)$/)){const {execSync}=require('child_process');try{execSync('npx prettier --write \"'+f+'\" 2>/dev/null',{stdio:'ignore'});}catch(e){}}});\""
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let b='';process.stdin.on('data',c=>b+=c);process.stdin.on('end',()=>{const d=JSON.parse(b);const log=new Date().toISOString()+' | '+d.tool_name+' | '+(d.tool_input&&d.tool_input.command||d.tool_input&&d.tool_input.file_path||'')+' | exit:'+(d.exit_code||0)+'\\n';require('fs').appendFileSync('.claude/tool.log',log);});\""
          }
        ]
      }
    ]
  }
}
