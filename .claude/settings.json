{
  "permissions": {
    "additionalDirectories": [],
    "allow": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-start.cjs"
          },
          {
            "type": "command",
            "command": "node scripts/memory-integrity.cjs"
          },
          {
            "type": "command",
            "command": "node scripts/drift-check.cjs verify || true"
          },
          {
            "type": "command",
            "command": "node scripts/component-validation.cjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/bash-blocker.cjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/file-protection.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/handoff-generator.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/prettier-format.cjs"
          },
          {
            "type": "command",
            "command": "node scripts/quality-gate.cjs"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-tracker.cjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session-stop.cjs"
          },
          {
            "type": "command",
            "command": "node scripts/drift-check.cjs capture"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/mcp-sequential-thinking"
      ]
    }
  }
}
