# Website Template — Environment Variables
# Copy this file to .env and fill in your values.

# Sanity CMS (required for CMS features, optional for static content)
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Site URL (used for canonical URLs, OG images, sitemaps)
SITE_URL=http://localhost:4321

# Google Analytics (optional — leave empty to disable)
GA_ID=
